@{
    ViewData["Title"] = "Valour: Community First Platform";
    ViewData["main-class"] = "homepage-content";
}

<section class="hero-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-8 col-lg-10 hero-content text-center" data-aos="fade-up">
                <h1 class="title-gradient">Community first.</h1>
                <p class="hero-subtitle">Join the movement for a more flexible, transparent, and open platform made by communities for communities.</p>
                <div class="hero-download-panel" data-download-picker>
                    <p class="hero-platform-note" data-platform-note>Recommended for your device</p>
                    <div class="hero-actions">
                        <a href="https://github.com/Valour-Software/Valour/releases/latest/download/ValourLauncher.exe"
                           class="btn btn-gradient btn-hero download-option"
                           data-download="windows"
                           data-platform-option="windows">
                            <i class="bi bi-windows"></i> Download for Windows
                        </a>
                        <a href="https://github.com/Valour-Software/Valour/releases/latest/download/gg.valour.app-Signed.apk"
                           class="btn btn-outline btn-hero download-option"
                           data-download="android"
                           data-platform-option="android">
                            <i class="bi bi-android2"></i> Download for Android
                        </a>
                        <a href="https://app.valour.gg"
                           class="btn btn-outline btn-hero download-option"
                           data-platform-option="web">
                            Open on Web <i class="bi bi-arrow-right"></i>
                        </a>
                        <button type="button" class="btn btn-ghost btn-hero view-all-downloads" data-show-downloads>
                            View all downloads
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="row justify-content-center">
            <div class="col-xl-10 hero-image" data-aos="fade-up" data-aos-delay="200">
                <div class="hero-reel-shell">
                    <div class="hero-reel-glow"></div>
                    <div class="image-card sm-rounded-image hero-preview-card hero-reel-card">
                        <video class="hero-reel"
                               autoplay
                               muted
                               loop
                               playsinline
                               preload="metadata"
                               poster="media/images/platform-md.webp"
                               aria-label="Preview of the Valour platform">
                            <source src="media/videos/platform-reel.mp4" type="video/mp4">
                        </video>
                    </div>
                    <div class="hero-reel-badge">
                        <i class="bi bi-play-circle-fill"></i>
                        Platform preview
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="features" class="features-section">
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="section-subtitle">PLATFORM</span>
            <h2 class="title-gradient">Powerful Features</h2>
            <p class="section-description">Take advantage of advanced features made capable by our unique tech stack.</p>
        </div>

        <div class="row features-grid">
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-window-stack"></i>
                    </div>
                    <h3>Multi-window Chat</h3>
                    <p>Chat in multiple channels at once, even across communities with our in-app window management system.</p>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-coin"></i>
                    </div>
                    <h3>Economy System</h3>
                    <p>Reward your community members and create engaging experiences with our integrated economy system.</p>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="bi bi-award"></i>
                    </div>
                    <h3>Item System</h3>
                    <p>Show off your accomplishments and be immersed like never before with our customizable item system.</p>
                </div>
            </div>
        </div>

        <div class="platform-preview" data-aos="fade-up">
            <img src="media/images/platform-lg.webp" alt="The Valour platform" class="img-fluid rounded-image">
        </div>
    </div>
</section>

<section class="performance-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 performance-content" data-aos="fade-right">
                <div class="section-header">
                    <span class="section-subtitle">TECHNOLOGY</span>
                    <h2 class="title-gradient-reverse">Next-gen Performance</h2>
                    <p class="section-description">Experience blazing fast speeds with our optimized tech stack.</p>
                </div>
                <div class="performance-features">
                    <div class="performance-feature">
                        <div class="feature-check"><i class="bi bi-check-circle-fill"></i></div>
                        <div>
                            <h4>Built on Blazor & WebAssembly</h4>
                            <p>While other apps sacrifice your computer's resources with Electron, we use cutting-edge web technologies for superior speed.</p>
                        </div>
                    </div>
                    <div class="performance-feature">
                        <div class="feature-check"><i class="bi bi-check-circle-fill"></i></div>
                        <div>
                            <h4>Node-based Backend</h4>
                            <p>Our custom node-based backend system allows large communities to get the performance they need - without disabling core features.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 performance-image" data-aos="fade-left">
                <div class="image-card floating">
                    <img src="media/screencaps/performance.webp" alt="Browser performance" class="img-fluid rounded-image">
                </div>
            </div>
        </div>
    </div>
</section>

<section class="opensource-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 opensource-image" data-aos="fade-right">
                <div class="image-card">
                    <img src="media/screencaps/opensource-3.webp" alt="Open Source Contributions" class="img-fluid rounded-image">
                    <div class="card-badge">
                        <i class="bi bi-github"></i> Open Source
                    </div>
                </div>
            </div>
            <div class="col-lg-6 opensource-content" data-aos="fade-left" style="padding-left: 50px">
                <div class="section-header">
                    <span class="section-subtitle">TRANSPARENCY</span>
                    <h2 class="title-gradient-blue">Open Source, Privacy Focused</h2>
                    <p class="section-description">We're an open book. Built by volunteers with no corporate funding.</p>
                </div>
                <div class="opensource-values">
                    <div class="value-item">
                        <i class="bi bi-shield-check"></i>
                        <div>
                            <h4>Privacy First</h4>
                            <p>Valour will never sell your data, and holds your privacy as critical to our mission.</p>
                        </div>
                    </div>
                    <div class="value-item">
                        <i class="bi bi-eye"></i>
                        <div>
                            <h4>Fully Transparent</h4>
                            <p>If you don't trust us, you can go look at the code yourself!</p>
                        </div>
                    </div>
                    <div class="value-item">
                        <i class="bi bi-people"></i>
                        <div>
                            <h4>Community Driven</h4>
                            <p>We are always ready for new team members to make this a reality.</p>
                        </div>
                    </div>
                </div>
                <a href="https://github.com/Valour-Software/Valour" class="btn btn-gradient mt-4">
                    Our Source Code <i class="bi bi-github"></i>
                </a>
            </div>
        </div>
    </div>
</section>

<section id="download" class="download-section">
    <div class="container">
        <div class="section-header text-center" data-aos="fade-up">
            <span class="section-subtitle">DOWNLOAD</span>
            <h2 class="title-gradient">Get the Valour App</h2>
            <p class="section-description">Download the latest release straight from GitHub. Prefer the browser? <a href="https://app.valour.gg">Open the web app</a>.</p>
        </div>

        <div class="row download-grid justify-content-center">
            <div class="col-md-5" data-aos="fade-up" data-aos-delay="100">
                <div class="download-card">
                    <div class="download-icon"><i class="bi bi-windows"></i></div>
                    <h3>Windows</h3>
                    <p>The Valour desktop launcher for Windows.</p>
                    <a href="https://github.com/Valour-Software/Valour/releases/latest/download/ValourLauncher.exe"
                       class="btn btn-gradient btn-lg" data-download="windows">
                        <i class="bi bi-download"></i> Download for Windows
                    </a>
                </div>
            </div>
            <div class="col-md-5" data-aos="fade-up" data-aos-delay="200">
                <div class="download-card">
                    <div class="download-icon"><i class="bi bi-android2"></i></div>
                    <h3>Android</h3>
                    <p>The Valour app as a signed Android APK.</p>
                    <a href="https://github.com/Valour-Software/Valour/releases/latest/download/gg.valour.app-Signed.apk"
                       class="btn btn-outline btn-lg" data-download="android">
                        <i class="bi bi-download"></i> Download for Android
                    </a>
                </div>
            </div>
        </div>

        <p class="download-note text-center">
            Looking for older versions? Browse all
            <a href="https://github.com/Valour-Software/Valour/releases" target="_blank">GitHub releases</a>.
        </p>
    </div>
</section>

<section class="cta-section">
    <div class="container">
        <div class="cta-card" data-aos="zoom-in">
            <h2 class="title-gradient">Ready to join our community?</h2>
            <p>Experience a more flexible, transparent, and open platform today.</p>
            <div class="cta-buttons">
                <a href="https://app.valour.gg" class="btn btn-gradient btn-lg">
                    Open on Web <i class="bi bi-arrow-right"></i>
                </a>
                <a href="https://github.com/Valour-Software/Valour" class="btn btn-outline btn-lg">
                    <i class="bi bi-github"></i> Contribute
                </a>
            </div>
        </div>
    </div>
</section>
