@implements IDisposable
@inject MessageService MessageService
@using Valour.Client.Components.Messages.Embeds.Items

@if (Embed is null)
{
	return;
}

<CascadingValue Value="@this" IsFixed="true">
	<CascadingValue Value="@MessageComponent">
		<div class="embed" style="@CurrentPage.Style">
			@if (CurrentPage.Title is not null)
			{
				<div class="embed-title" style="@CurrentPage.TitleStyle">
					@((MarkupString)MarkdownManager.GetHtml(CurrentPage.Title))
				</div>
			}

			@foreach (var item in CurrentPage.Children)
			{
				<EmbedItemComponent Item="@item" @key="@(item.Id ?? (object)item)" />
			}

			@if (Embed.Pages.Count > 1 && !Embed.HideChangePageArrows)
			{
				<div class="embed-page-arrows">
					<button @onclick="PrevPage" class="embed-page-arrow">&lt;</button>
					<span class="embed-page-number">@(_pageIndex + 1) / @Embed.Pages.Count</span>
					<button @onclick="NextPage" class="embed-page-arrow">&gt;</button>
				</div>
			}

			@if (CurrentPage.Footer is not null)
			{
				<div class="embed-footer" style="@CurrentPage.FooterStyle">
					@((MarkupString)MarkdownManager.GetHtml(CurrentPage.Footer))
				</div>
			}
		</div>
	</CascadingValue>
</CascadingValue>

@code {

	[Parameter]
	public Message Message { get; set; }

	[Parameter]
	public MessageAttachment Attachment { get; set; }

	[Parameter]
	public MessageComponent MessageComponent { get; set; }

	public Embed Embed { get; private set; }

	public EmbedRegistry Registry { get; } = new();

	private int _pageIndex;
	private long _revision;

	public EmbedPage CurrentPage => Embed.Pages[_pageIndex];

	protected override void OnInitialized()
	{
		MessageService.EmbedUpdated += OnEmbedUpdate;
		MessageService.MessageEdited += OnMessageEdited;

		Attachment ??= Message.EmbedAttachment;
		SetEmbed(Attachment?.Embed);
	}

	public void Dispose()
	{
		MessageService.EmbedUpdated -= OnEmbedUpdate;
		MessageService.MessageEdited -= OnMessageEdited;
	}

	private void SetEmbed(Embed embed)
	{
		Embed = embed;
		if (embed is null)
			return;

		_revision = embed.Revision;
		_pageIndex = ClampPage(embed.StartPage);
	}

	private int ClampPage(int index) =>
		Math.Clamp(index, 0, Math.Max(0, Embed.Pages.Count - 1));

	// ---- Page navigation ----

	public void GoToPage(int index)
	{
		if (Embed is null)
			return;

		_pageIndex = ClampPage(index);
		StateHasChanged();
	}

	public void NextPage() => GoToPage(_pageIndex + 1 >= Embed.Pages.Count ? 0 : _pageIndex + 1);

	public void PrevPage() => GoToPage(_pageIndex - 1 < 0 ? Embed.Pages.Count - 1 : _pageIndex - 1);

	// ---- Interactions ----

	/// <summary>
	/// Posts an interaction (click or form submit) for this embed's message.
	/// The server derives all context from the message id.
	/// </summary>
	public async Task SendInteractionAsync(EmbedInteractionEventType eventType, string elementId, string formId = null, List<EmbedFormData> formData = null)
	{
		var request = new EmbedInteractionRequest
		{
			MessageId = Message.Id,
			EventType = eventType,
			ElementId = elementId,
			FormId = formId,
			FormData = formData,
		};

		await Message.Node.HttpClient.PostAsJsonAsync("api/embed/interact", request);
	}

	// ---- Live updates ----

	private Task OnMessageEdited(Message message)
	{
		if (message.Id != Message.Id)
			return Task.CompletedTask;

		return InvokeAsync(() =>
		{
			var updated = message.Attachments?.FirstOrDefault(x => x.Id == Attachment?.Id) ??
			              message.Attachments?.FirstOrDefault(x => x.Type == MessageAttachmentType.Embed);
			if (updated is null || Attachment is null)
				return;

			Attachment.SetEmbedPayload(updated.Data);
			SetEmbed(Attachment.Embed);
			StateHasChanged();
		});
	}

	private Task OnEmbedUpdate(EmbedUpdate update)
	{
		if (update.TargetMessageId != Message.Id)
			return Task.CompletedTask;

		return InvokeAsync(() =>
		{
			if (Embed is null || Attachment is null)
				return;

			// Drop stale updates; bots that leave Revision 0 opt out of ordering
			if (update.Revision < _revision)
				return;
			_revision = Math.Max(_revision, update.Revision);

			if (update.NewEmbedContent is not null)
				ApplyFullUpdate(update.NewEmbedContent);
			else if (update.ChangedItemsContent is not null)
				ApplyTargetedUpdate(update.ChangedItemsContent);
		});
	}

	private void ApplyFullUpdate(string newContent)
	{
		// Snapshot user-entered input values so they survive the replace
		var keptValues = new Dictionary<string, string>();
		foreach (var item in Embed.EnumerateItems())
		{
			if (item is IFormInputItem { Id: not null, KeepValueOnUpdate: true } input && input.Value is not null)
				keptValues[input.Id] = input.Value;
		}

		var previousPage = _pageIndex;

		Attachment.SetEmbedPayload(newContent);
		var embed = Attachment.Embed;
		if (embed is null)
		{
			// Malformed replacement: render nothing rather than stale content
			Embed = null;
			StateHasChanged();
			return;
		}

		Embed = embed;
		_revision = Math.Max(_revision, embed.Revision);
		_pageIndex = ClampPage(embed.KeepPageOnUpdate ? previousPage : embed.StartPage);

		foreach (var item in embed.EnumerateItems())
		{
			if (item is IFormInputItem { Id: not null, KeepValueOnUpdate: true } input
			    && keptValues.TryGetValue(input.Id, out var kept))
				input.Value = kept;
		}

		StateHasChanged();
	}

	private void ApplyTargetedUpdate(string changedContent)
	{
		var items = EmbedParser.TryParseItems(changedContent);
		if (items is null)
			return;

		var needsFullRender = false;

		foreach (var item in items)
		{
			if (item?.Id is null)
				continue;

			// Preserve the user's typed value across the swap
			if (item is IFormInputItem { KeepValueOnUpdate: true } incoming
			    && Embed.FindItem(item.Id) is IFormInputItem { Value: not null } existing)
				incoming.Value = existing.Value;

			if (!Embed.ReplaceItem(item))
				continue;

			if (Registry.TryGet(item.Id, out var component))
				component.RefreshFromModel();
			else
				needsFullRender = true;
		}

		if (needsFullRender)
			StateHasChanged();
	}
}
