@inherits EmbedItemComponentBase
@inject IJSRuntime JsRuntime

@if (Media.Attachment is not null)
{
	<div class="embed-item @Media.Classes" style="@ContainerStyle" @onclick="HandleClickAsync">
		<div class="attachment-wrapper">
			<DynamicComponent Type="Media.Attachment.GetComponentType()" Parameters="@ComponentParameters" />
		</div>
	</div>
}

@code {
	[CascadingParameter]
	public MessageComponent MessageComponent { get; set; }

	private EmbedMediaItem Media => (EmbedMediaItem)Item;

	private bool HasSizeStyle =>
		Media.Style is not null &&
		(Media.Style.Contains("width") || Media.Style.Contains("height"));

	private string ContainerStyle =>
		Media.ClickTarget is not null ? $"cursor: pointer; {Media.Style}" : Media.Style;

	private Dictionary<string, object> ComponentParameters
	{
		get
		{
			var parameters = new Dictionary<string, object>
			{
				{ "Attachment", Media.Attachment },
				{ "MessageComponent", MessageComponent },
			};

			if (HasSizeStyle)
			{
				parameters.Add("CustomStyle", Media.Style);
				if (Media.Attachment.Type == MessageAttachmentType.Image)
					parameters.Add("Clickable", false);
			}

			return parameters;
		}
	}

	private Task HandleClickAsync() =>
		EmbedClickHandler.HandleClickAsync(Media, Root, EnclosingForm, JsRuntime);
}
