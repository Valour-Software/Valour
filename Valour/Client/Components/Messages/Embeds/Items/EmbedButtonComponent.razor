@inherits EmbedItemComponentBase
@inject IJSRuntime JsRuntime

<button type="button" class="btn embed-item embed-button @Button.Classes" style="@Button.Style" @onclick="HandleClickAsync">
	@foreach (var child in Button.Children)
	{
		<EmbedItemComponent Item="@child" Nested="true" @key="@(child.Id ?? (object)child)" />
	}
</button>

@code {
	private EmbedButtonItem Button => (EmbedButtonItem)Item;

	private Task HandleClickAsync() =>
		EmbedClickHandler.HandleClickAsync(Button, Root, EnclosingForm, JsRuntime);
}
