@* Dispatches an embed item to its component by type. *@

@switch (Item)
{
	case EmbedTextItem:
		<EmbedTextItemComponent Item="@Item" Nested="@Nested" />
		break;
	case EmbedButtonItem:
		<EmbedButtonComponent Item="@Item" />
		break;
	case EmbedInputBoxItem:
		<EmbedInputBoxComponent Item="@Item" />
		break;
	case EmbedDropDownItem:
		<EmbedDropDownComponent Item="@Item" />
		break;
	case EmbedFormItem:
		<EmbedFormComponent Item="@Item" />
		break;
	case EmbedProgressItem:
		<EmbedProgressComponent Item="@Item" />
		break;
	case EmbedMediaItem:
		<EmbedMediaComponent Item="@Item" />
		break;
	case EmbedRowItem:
		<EmbedRowComponent Item="@Item" />
		break;
}

@code {
	[Parameter]
	public EmbedItem Item { get; set; }

	/// <summary>
	/// True when rendered inside another item (e.g. a button label),
	/// which suppresses top-level item spacing.
	/// </summary>
	[Parameter]
	public bool Nested { get; set; }
}
