@inherits AttachmentComponent
@inject IJSRuntime JsRuntime

<div class="soundcloud-embed" id="@_id">
</div>

<style>
    .soundcloud-embed {
        border-radius: var(--radius-md);
        overflow: hidden;
        max-width: 100%;
    }

    .soundcloud-embed iframe {
        border: none;
        border-radius: var(--radius-md);
    }
</style>

@code {
    private readonly string _id = "soundcloud-embed-" + Guid.NewGuid().ToString();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(Attachment.Data))
        {
            await JsRuntime.InvokeVoidAsync("injectEmbed", _id, Attachment.Data, null);
        }
    }
}
