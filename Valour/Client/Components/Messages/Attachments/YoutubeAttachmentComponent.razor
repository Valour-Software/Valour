@inherits AttachmentComponent

<div class="youtube-container">
    <iframe
        class="youtube-embed"
        width="560"
        height="315"
        src="@Attachment.Location"
        title="YouTube embed"
        frameborder="0"
        loading="lazy"
        allow="clipboard-write; encrypted-media; picture-in-picture; web-share"
        allowfullscreen>
    </iframe>
</div>