@inherits AttachmentComponent

@if (Attachment?.Missing == true || string.IsNullOrWhiteSpace(_location))
{
    <FileAttachmentComponent Message="@Message" Attachment="@Attachment" />
}
else
{
    <audio controls preload="auto" playsinline>
        <source src="@_location" type="@Attachment.MimeType" />
    </audio>
}

@code {
    [Parameter]
    public string CustomStyle { get; set; }
    
    private string _location;

    protected override async Task OnInitializedAsync()
    {
        _location = await Attachment.GetSignedUrl(Message.Client, Message.Node);
    }

}

