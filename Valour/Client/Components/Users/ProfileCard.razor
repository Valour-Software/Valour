@inject ValourClient Client
@inject FriendService FriendService
@inject ChannelService ChannelService

<div id="@Id" class="card-wrapper" style="@CardStyle">
    <div class="card-glow"></div>
    <div
        @onclick:stopPropagation="true"
        class="profile-card">
        <span class="card-bg @(HasAnimatedBorder ? "animated-border" : null)" style="@CardBackground"></span>
        <div class="card-shell">
            @if (HasBackgroundImage)
            {
                <div class="inner-bg" style="@BackgroundImage"></div>
            }

            <div class="shell-overlay"></div>

            <div class="card-content">
                <section class="hero-section">
                    <div class="hero-topline">
                        <div class="presence-pill @_statusClass">
                            <span class="presence-dot"></span>
                            <span>@_presenceName</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_lastSeenText))
                        {
                            <div class="meta-pill">
                                <i class="bi bi-clock-history"></i>
                                <span>@_lastSeenText</span>
                            </div>
                        }
                    </div>

                    <div class="identity-section">
                        <div class="identity-main">
                            <div class="avatar-frame">
                                <img class="pfp" alt="@_displayName's profile picture" src="@_pfpUrl" @onerror="OnPfpError"/>
                            </div>

                            <div class="identity-copy">
                                <div class="identity-row">
                                    <div class="name-stack">
                                        <p class="eyebrow">Profile</p>
                                        <h2 class="display-name">@_displayName</h2>
                                        <p class="name-and-tag">@_nameAndTag</p>
                                    </div>
                                </div>

                                @if (HasBadges)
                                {
                                    <div class="badge-cluster">
                                        @if (User.HasStargazer)
                                        {
                                            <div class="badge-chip stargazer">
                                                <img alt="Stargazer badge" src="@StarBadge.GetDataUri(User.Id, User.GetStarColor1(), User.GetStarColor2())"/>
                                                <span>Stargazer</span>
                                            </div>
                                        }
                                        @if (User.Bot)
                                        {
                                            <div class="badge-chip bot">
                                                <i class="bi bi-cpu-fill"></i>
                                                <span>Bot</span>
                                            </div>
                                        }
                                        @if (User.ValourStaff)
                                        {
                                            <div class="badge-chip staff">
                                                <i class="bi bi-patch-check-fill"></i>
                                                <span>Staff</span>
                                            </div>
                                        }
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(User?.PriorName))
                                {
                                    <p class="meta-line">
                                        <i class="bi bi-arrow-repeat"></i>
                                        <span>Formerly @User.PriorName</span>
                                    </p>
                                }
                            </div>
                        </div>

                    </div>
                </section>

                @if (HasHeadline)
                {
                    <section class="headline-section">
                        <p class="headline">@HeadlineText</p>
                    </section>
                }

                @if (ShowActions)
                {
                    <section class="action-section">
                        <button class="v-btn large action-button message-button" @onclick="OnClickMessage">
                            <i class="bi bi-envelope-fill"></i>
                            <span>Message</span>
                        </button>

                        @if (_isFriend)
                        {
                            <button class="v-btn large action-button friend-button" @onclick="OnClickRemoveFriend">
                                <i class="bi bi-person-heart"></i>
                                <span>Remove Friend</span>
                            </button>
                        }
                        else if (_isFriendRequested)
                        {
                            <button class="v-btn large action-button friend-button" @onclick="OnClickRemoveFriend">
                                <i class="bi bi-person-heart"></i>
                                <span>Cancel Request</span>
                            </button>
                        }
                        else
                        {
                            <button class="v-btn large action-button friend-button" @onclick="OnClickAddFriend">
                                <i class="bi bi-person-heart"></i>
                                <span>Add Friend</span>
                            </button>
                        }
                    </section>
                }

                <section class="details-section">
                    <div class="feature-panel status-panel">
                        <p class="panel-label">Status</p>
                        <p class="status-text">@StatusText</p>
                    </div>

                    <div class="feature-panel bio-panel">
                        <p class="panel-label">Bio</p>
                        <div class="bio-scroll">
                            <p class="body-text">@BioText</p>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>

@code {

    [Parameter]
    public PlanetMember Member { get; set; }

    [Parameter]
    public User User { get; set; }

    [Parameter]
    public UserProfile Profile { get; set; }

    [Parameter]
    public string CssStyle { get; set; }

    private string CardStyle
    {
        get
        {
            var baseStyle = string.IsNullOrWhiteSpace(CssStyle)
                ? string.Empty
                : $"{CssStyle.Trim().TrimEnd(';')};";

            return baseStyle +
                   $"--profile-primary: {GetProfileColor(Profile?.PrimaryColor, "var(--p-cyan-purple)")};" +
                   $"--profile-secondary: {GetProfileColor(Profile?.SecondaryColor, "var(--p-cyan)")};" +
                   $"--profile-tertiary: {GetProfileColor(Profile?.TertiaryColor, "var(--v-purple)")};" +
                   $"--profile-border: {GetProfileColor(Profile?.BorderColor, "var(--main-5)")};" +
                   $"--profile-glow: {GetProfileColor(Profile?.GlowColor, "var(--p-cyan)")};" +
                   $"--profile-text: {GetProfileColor(Profile?.TextColor, "var(--font-color)")};";
        }
    }

    private string BackgroundImage
    {
        get
        {
            if (User?.Subscription == null)
                return string.Empty;

            if (string.IsNullOrWhiteSpace(Profile?.BackgroundImage))
                return string.Empty;

            return $"background-image: url({Profile.BackgroundImage});";
        }
    }

    private bool HasBackgroundImage => !string.IsNullOrWhiteSpace(BackgroundImage);

    private string CardBackground
    {
        get
        {
            var border = GetProfileColor(Profile?.BorderColor, "var(--main-5)");
            var primary = GetProfileColor(Profile?.PrimaryColor, border);
            var secondary = GetProfileColor(Profile?.SecondaryColor, primary);
            var tertiary = GetProfileColor(Profile?.TertiaryColor, secondary);

            var bg = User?.Subscription == null || string.IsNullOrWhiteSpace(Profile?.PrimaryColor)
                ? $"background: linear-gradient(135deg, {border} 0%, color-mix(in srgb, {border} 60%, black) 100%);"
                : $"background: conic-gradient(from var(--profile-border-angle) at 50% 50%, {primary} 0deg, {secondary} 120deg, {tertiary} 240deg, {primary} 360deg);";

            return bg;
        }
    }

    private bool HasAnimatedBorder => Profile?.AnimatedBorder == true;
    private bool HasBadges => User?.HasStargazer == true || User?.Bot == true || User?.ValourStaff == true;
    private bool HasHeadline => !string.IsNullOrWhiteSpace(Profile?.Headline);
    private bool ShowActions => User is not null && Client.Me is not null && User.Id != Client.Me.Id;
    private string StatusText => string.IsNullOrWhiteSpace(_status) ? "No status set." : _status;
    private string HeadlineText => Profile?.Headline?.Trim() ?? string.Empty;
    private string BioText => string.IsNullOrWhiteSpace(Profile?.Bio) ? "No bio written yet." : Profile.Bio;

    public readonly string Id = Guid.NewGuid().ToString();

    private string _displayName = "Unknown User";
    private string _nameAndTag = string.Empty;
    private string _presenceName = "Offline";
    private string _status = string.Empty;
    private string _pfpUrl = ISharedUser.DefaultAvatar;
    private string _statusClass = "offline";
    private string _lastSeenText = string.Empty;

    private bool _isFriend;
    private bool _isFriendRequested;

    protected override void OnParametersSet()
    {
        SyncDisplayState();
    }

    public Task LoadDetailsAsync()
    {
        SyncDisplayState();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void SyncDisplayState()
    {
        if (User is null)
            return;

        _isFriendRequested = FriendService.OutgoingRequests.Any(x => x.Id == User.Id);
        _isFriend = FriendService.Friends.Any(x => x.Id == User.Id);

        _displayName = !string.IsNullOrWhiteSpace(Member?.Nickname) ? Member.Nickname : User.Name;
        _nameAndTag = User.NameAndTag;
        _presenceName = User.UserState?.Name ?? "Offline";
        _status = User.Status;
        _statusClass = string.IsNullOrWhiteSpace(User.UserState.CssClassName) ? "offline" : User.UserState.CssClassName;
        _lastSeenText = BuildLastSeenText();
        _pfpUrl = Member?.GetAvatar() ?? User.GetAvatar() ?? ISharedUser.DefaultAvatar;
    }

    private string BuildLastSeenText()
    {
        if (User is null || User.UserStateCode != 1)
            return string.Empty;

        var elapsed = DateTime.Now - User.TimeLastActive;

        if (elapsed.TotalSeconds <= 0)
            return string.Empty;

        return $"Last online {FormatElapsed(elapsed)} ago";
    }

    private static string FormatElapsed(TimeSpan elapsed)
    {
        if (elapsed.TotalHours >= 24)
        {
            var days = Math.Floor(elapsed.TotalDays);
            return days == 1 ? "1 day" : $"{days} days";
        }

        if (elapsed.TotalMinutes >= 60)
        {
            var hours = Math.Floor(elapsed.TotalHours);
            return hours == 1 ? "1 hour" : $"{hours} hours";
        }

        if (elapsed.TotalSeconds >= 60)
        {
            var minutes = Math.Floor(elapsed.TotalMinutes);
            return minutes == 1 ? "1 minute" : $"{minutes} minutes";
        }

        var seconds = Math.Floor(elapsed.TotalSeconds);
        return seconds == 1 ? "1 second" : $"{seconds} seconds";
    }

    private static string GetProfileColor(string color, string fallback)
    {
        return string.IsNullOrWhiteSpace(color) ? fallback : color;
    }

    private void OnPfpError()
    {
        _pfpUrl = User?.GetFailedAvatar() ?? ISharedUser.DefaultAvatar;
        StateHasChanged();
    }

    private async Task OnClickAddFriend()
    {
        var result = await FriendService.AddFriendAsync(User.NameAndTag);

        if (!result.Success)
        {
            Client.Logger.Log<ProfileCard>($"Failed to add friend:\n{result.Message}", "orange");
            return;
        }

        _isFriend = true;
        StateHasChanged();
    }

    private async Task OnClickRemoveFriend()
    {
        var result = await FriendService.RemoveFriendAsync(User.NameAndTag);

        if (!result.Success)
        {
            Client.Logger.Log<ProfileCard>($"Failed to remove friend:\n{result.Message}", "orange");
            return;
        }

        _isFriend = false;
        _isFriendRequested = false;
        StateHasChanged();
    }

    private async Task OnClickMessage()
    {
        var channel = await ChannelService.FetchDmChannelAsync(User.Id, true);
        var newWindowContent = await ChatWindowComponent.GetDefaultContent(channel);
        await WindowService.OpenWindowAtFocused(newWindowContent);
    }
}
