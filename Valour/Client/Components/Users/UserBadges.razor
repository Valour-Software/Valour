@using System.Globalization
@implements IDisposable

@* Standardized user badge row: stargazer, early user milestones, bot, staff *@

@if (_badges.Count == 0)
{
    return;
}

<div class="user-badges">
    @for (var i = 0; i < _badges.Count; i++)
    {
        var badge = _badges[i];
        <span class="badge-slot" style="@GetSlotStyle(i)" @key="@badge.CssClass">
            <TooltipTrigger>
                <ChildContent>
                    <span class="user-badge-item icon @badge.CssClass" style="@badge.Style" aria-label="@badge.Label">
                        <i class="bi @badge.Icon" aria-hidden="true"></i>
                    </span>
                </ChildContent>
                <TooltipContent>
                    <span>@badge.Label</span>
                </TooltipContent>
            </TooltipTrigger>
        </span>
    }
</div>

@code {
    [Parameter]
    public User User { get; set; }

    private record BadgeDef(string CssClass, string Icon, string Label, string Style = null);

    private readonly List<BadgeDef> _badges = new();
    private bool _isModded;

    protected override void OnInitialized()
    {
        ModdedPresenceService.Updated += OnPresenceUpdated;
    }

    private void OnPresenceUpdated()
    {
        // Most refresh ticks won't change whether *this* user is in the online
        // set, so skip the rebuild/render entirely unless it actually flipped -
        // avoids needless allocations and re-renders across every visible avatar.
        if (User is null || ModdedPresenceService.OnlineUserIds.Contains(User.Id) == _isModded)
            return;

        BuildBadges();
        InvokeAsync(StateHasChanged);
    }

    protected override void OnParametersSet()
    {
        BuildBadges();
    }

    private void BuildBadges()
    {
        _badges.Clear();

        if (User is null)
            return;

        _isModded = ModdedPresenceService.OnlineUserIds.Contains(User.Id);
        if (_isModded)
        {
            _badges.Add(new BadgeDef("modded-client", "bi-joystick", "Modded Client",
                "--user-badge-star-start: #7c3aed; --user-badge-star-end: #06b6d4;"));
        }

        if (User.HasStargazer)
        {
            _badges.Add(new BadgeDef("stargazer", "bi-star-fill", "Stargazer",
                $"--user-badge-star-start: {User.GetStarColor1()}; --user-badge-star-end: {User.GetStarColor2()};"));
        }

        if (User.Id <= 22113735421460480)
        {
            _badges.Add(new BadgeDef("milestone-1k", "bi-award-fill", "First 1k users"));
        }
        else if (User.Id <= 42076534464053248)
        {
            _badges.Add(new BadgeDef("milestone-10k", "bi-award-fill", "First 10k users"));
        }

        if (User.Bot)
        {
            _badges.Add(new BadgeDef("bot", "bi-cpu-fill", "Bot"));
        }

        if (User.ValourStaff)
        {
            _badges.Add(new BadgeDef("staff", "bi-shield-fill", "Valour Staff"));
        }
    }

    /// <summary>
    /// Overlapping cluster: badges overlap slightly, the center badge stacks
    /// on top, and rows of 3+ dip outward in a gentle arc.
    /// </summary>
    private string GetSlotStyle(int index)
    {
        var count = _badges.Count;
        var center = (count - 1) / 2.0;
        var dist = Math.Abs(index - center);

        var z = count - (int)Math.Ceiling(dist);
        var style = $"z-index: {z};";

        if (index > 0)
            style += " margin-left: -3px;";

        if (count >= 3)
        {
            var drop = 3.0 * (dist * dist) / (center * center);
            style += $" transform: translateY({drop.ToString("0.##", CultureInfo.InvariantCulture)}px);";
        }

        return style;
    }

    public void Dispose()
    {
        ModdedPresenceService.Updated -= OnPresenceUpdated;
    }
}
