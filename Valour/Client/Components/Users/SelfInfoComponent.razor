@inject ValourClient Client
@implements IDisposable

<div class="self-info">
    <UserInfoComponent User="@Client.Me" ShowBadges="false" />
    @if (Client.EcoService.SelfGlobalAccount is not null)
    {
        <span class="credit-balance" title="Valour Credits balance">
            <i class="bi bi-coin"></i>
            @Client.EcoService.SelfGlobalAccount.BalanceValue.ToString("0.##") VC
        </span>
    }
    <button id="user-edit-button" class="settings-button" aria-label="User settings button"
            @onkeydown="@(e => { if (e.Key == "Enter") OnClickUserSettings(); })"
            @onclick="@OnClickUserSettings">
        <img alt="User settings button" src="_content/Valour.Client/media/Settings-Icon.svg" class="settings-icon" />
    </button>
</div>
@code {
    [CascadingParameter]
    public ModalRoot ModalRoot { get; set; }

    protected override void OnInitialized()
    {
        if (Client.EcoService.SelfGlobalAccount is not null)
            Client.EcoService.SelfGlobalAccount.Updated += OnAccountUpdated;
    }

    private void OnAccountUpdated(ModelUpdatedEvent<EcoAccount> eventData)
    {
        _ = InvokeAsync(StateHasChanged);
    }
    
    private void OnClickUserSettings()
    {
        var data = new EditUserComponent.ModalParams()
        {
            User = Client.Me
        };
        
        ModalRoot.OpenModal<EditUserComponent>(data);
    }

    public void Dispose()
    {
        if (Client.EcoService.SelfGlobalAccount is not null)
            Client.EcoService.SelfGlobalAccount.Updated -= OnAccountUpdated;
    }
}
