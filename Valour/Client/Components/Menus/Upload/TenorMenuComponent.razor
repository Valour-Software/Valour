@inject IJSRuntime JsRuntime
@implements IAsyncDisposable
@inject ValourClient Client
@inject TenorService TenorService

@using Valour.TenorTwo.Models
@using Valour.TenorTwo.Responses

<div style="display: @(_visible ? "absolute" : "none")" id="tenor-bg-@ChannelWindow.WindowCtx.Id" class="tenor-bg">
    <div class="tenor-toolbar">
        <input @bind="_searchTerm" @bind:event="oninput" @onkeyup="OnSearchChange" class="form-control mb-2" placeholder="Search Klipy..." />
        <button type="button" class="v-btn secondary favorites-shortcut" @onclick="OnClickFavoritesShortcut">❤️ Favorites</button>
    </div>
    <div class="masonry-scroller">
        <div id="masonry-root-@ChannelWindow.WindowCtx.Id" class="masonry-root">
            @if (SearchResults?.Results is not null)
            {
                // Built once per render instead of doing a linear Any() scan (with a
                // fresh closure allocation) for every single cell below.
                var favoriteIds = new HashSet<string>(TenorService.TenorFavorites.Select(x => x.TenorId));

                foreach (var result in SearchResults.Results)
                {
                    var media = result.GetFormat(MediaFormatType.tinygif);
                    if (media is null)
                        return;

                    var addGif = result;
                    <div @key="@result.Id" class="masonry-cell" @onclick="async () => await OnClickGif(result)">
                        @if (favoriteIds.Contains(result.Id))
                        {
                            <h3 class="favorite" @onclick="() => OnClickUnfavorite(addGif)" @onclick:stopPropagation="true">❤️</h3>
                        }
                        else
                        {
                            <h3 class="favorite" @onclick="() => OnClickFavorite(addGif)" @onclick:stopPropagation="true">🤍</h3>
                        }
                        <img data-natwidth="@media.Dims[0]" data-natheight="@media.Dims[1]" class="item" src="@media.Url" alt="@result.Title"/>
                    </div>
                }
            }
            else if (_categoryTiles is not null)
            {
                foreach (var tile in _categoryTiles)
                {
                    <div @key="@tile.SearchTerm" class="masonry-cell" @onclick="() => OnClickCategoryTile(tile.SearchTerm)">
                        <h2>@tile.Name</h2>
                        @if (tile.ThumbnailUrl is not null)
                        {
                            <img data-natwidth="210" data-natheight="180" class="item" src="@tile.ThumbnailUrl" alt="@tile.Name"/>
                        }
                    </div>
                }
            }
        </div>
    </div>
    <div class="powered-by">Powered by KLIPY</div>
</div>

@code {
    [Parameter]
    public ChatWindowComponent ChannelWindow { get; set; }
    
    /// <summary>
    /// Module for calling Javascript functions
    /// </summary>
    private IJSObjectReference _jsModule;
    
    /// <summary>
    /// Dotnet object reference for use in Javascript
    /// </summary>
    private DotNetObjectReference<TenorMenuComponent> _thisRef;
    
    private MediaResponse SearchResults { get; set; }

    private List<CategoryTile> _categoryTiles;
    private bool _loadingCategoryTiles;

    private static readonly (string Name, string SearchTerm)[] CategoryDefinitions =
    {
        ("Happy", "happy"),
        ("Sad", "sad"),
        ("Love", "love"),
        ("Excited", "excited"),
        ("Angry", "angry"),
        ("Surprised", "surprised"),
        ("Laughing", "laughing"),
        ("Dance", "dance"),
        ("Yes", "yes"),
        ("No", "no"),
        ("Ok", "ok"),
        ("Hello", "hello"),
    };

    private class CategoryTile
    {
        public string Name { get; init; }
        public string SearchTerm { get; init; }
        public string ThumbnailUrl { get; set; }
    }

    private string _searchTerm;

    private bool _visible = false;

    private bool _canRender = false;

    // Used for debouncing
    private string _newestSearch;
    private DateTime _lastLoad = DateTime.UtcNow;

    protected override bool ShouldRender()
        => _canRender;

    public void Refresh()
    {
        _canRender = true;
        StateHasChanged();
    }

    private async Task OnClickFavorite(TenorTwo.Models.Media media)
    {
        var favorite = new TenorFavorite(Client)
        {
            UserId = Client.Me.Id,
            TenorId = media.Id
        };

        await TenorService.AddTenorFavorite(favorite);
        
        Refresh();
    }

    private async Task OnClickUnfavorite(TenorTwo.Models.Media media)
    {
        var favorite = TenorService.TenorFavorites.FirstOrDefault(x => x.TenorId == media.Id);
        if (favorite is null)
            return;
        
        await TenorService.RemoveTenorFavorite(favorite);
        
        Refresh();
    }

    private async Task OnClickGif(TenorTwo.Models.Media media)
    {
        Hide();

        await ChannelWindow.InputComponent.AddTenor(media);

        // Register share to make Tenor (well, Klipy) happy
        await TenorService.Client.RegisterShare(media.Id, _searchTerm);
    }

    private async Task OnSearchChange()
    {
        // Strings are immutable, so this plain assignment already snapshots the current
        // value for the staleness check below - no need to copy the string.
        var term = _searchTerm;
        _newestSearch = _searchTerm;
        
        // If we're currently loading a result, wait to send off another request.
        if (_lastLoad.AddMilliseconds(500) > DateTime.UtcNow)
            await Task.Delay(500);
        
        _lastLoad = DateTime.UtcNow;

        if (string.IsNullOrWhiteSpace(_searchTerm))
        {
            SearchResults = null;
            await LoadCategoryTilesAsync();
            Refresh();
            return;
        }

        // There's been more typing since the delay and we're not the latest.
        // Cancel here.
        if (term != _searchTerm)
            return;

        await FocusAndScroll();

        if (_searchTerm == ":favorites:")
        {
            if (!TenorService.TenorFavorites.Any())
            {
                SearchResults = null;
                await LoadCategoryTilesAsync();
                Refresh();
                return;
            }

            SearchResults = await TenorService.GetFavoritePostsAsync();
        }
        else
            SearchResults = await TenorService.Client.Search(_searchTerm, 50, formatFilter: TenorService.Formats);

        Refresh();
    }

    private async Task OnClickFavoritesShortcut()
    {
        _searchTerm = ":favorites:";
        await OnSearchChange();
    }

    private async Task OnClickCategoryTile(string term)
    {
        _searchTerm = term;
        await OnSearchChange();
    }

    private async Task LoadCategoryTilesAsync()
    {
        if (_categoryTiles is not null || _loadingCategoryTiles)
            return;

        _loadingCategoryTiles = true;

        var tiles = CategoryDefinitions
            .Select(c => new CategoryTile { Name = c.Name, SearchTerm = c.SearchTerm })
            .ToList();

        await Task.WhenAll(tiles.Select(async tile =>
        {
            var response = await TenorService.Client.Search(tile.SearchTerm, 1, formatFilter: TenorService.Formats);
            var thumb = response?.Results?.FirstOrDefault()?.GetFormat(MediaFormatType.tinygif);
            if (thumb is not null)
                tile.ThumbnailUrl = thumb.Url;
        }));

        _categoryTiles = tiles;
        _loadingCategoryTiles = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _canRender = false;
        
        if (firstRender)
        {
            _thisRef = DotNetObjectReference.Create(this);
            _jsModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./_content/Valour.Client/Components/Menus/Upload/TenorMenuComponent.razor.js");
            await _jsModule.InvokeVoidAsync("setupHide", "tenor-bg-" + ChannelWindow.WindowCtx.Id, _thisRef);
        }
        
        await BuildMasonry(); 
    }

    public async Task FocusAndScroll()
    {
        await _jsModule.InvokeVoidAsync("focusAndScroll", "masonry-root-" + ChannelWindow.WindowCtx.Id);
    }

    public async Task BuildMasonry()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("buildMasonry", "masonry-root-" + ChannelWindow.WindowCtx.Id);
    }
    
    public async Task Show()
    {
        _visible = true;

        if (SearchResults is null && string.IsNullOrWhiteSpace(_searchTerm))
        {
            await LoadCategoryTilesAsync();
        }

        await FocusAndScroll();
        Refresh();
    }

    [JSInvokable]
    public void Hide()
    {
        if (!_visible)
            return;
        
        _visible = false;
        Refresh();
    }
    
    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        await _jsModule.DisposeAsync();
        _thisRef?.Dispose();
    }

}