@inject IJSRuntime JsRuntime

@if (_hidden)
{
    return;
}

@* Holds the entire component *@
<div
    @onclick="Close"
    class="profile-outer">
    @* Holds the actual profile *@
    <ProfileCard @ref="@_profileCard" User="@_user" Member="@_member" Profile="@_profile"></ProfileCard>
</div>

@code {
    private ProfileCard _profileCard;
    
    public static ProfilePopup Instance { get; private set; }

    private PlanetMember _member;
    private User _user;
    private UserProfile _profile;

    private bool _hidden = true;
    private int _posX;
    private int _posY;
    private string _corner = "bottomLeft";

    private bool _needsPositioning = false;
    private bool _needsDetailLoad = false;

    protected override void OnInitialized()
    {
        Instance = this;
        KeyboardListener.KeyDown += OnKeyDown;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_hidden || _profileCard is null)
            return;

        // The ProfileCard is captured via @ref, so it only exists once the
        // render triggered by OpenAsync has actually run. Loading details and
        // positioning must happen here, not inline in OpenAsync, otherwise
        // _profileCard is still null on the first open.
        if (_needsDetailLoad)
        {
            _needsDetailLoad = false;
            await _profileCard.LoadDetailsAsync();
        }

        if (_needsPositioning)
        {
            _needsPositioning = false;
            await JsRuntime.InvokeVoidAsync("positionRelativeTo", _profileCard.Id, _posX, _posY, _corner);
        }
    }

    public async Task OpenAsync(User user, int x, int y, string corner = "bottomLeft")
    {
        if (user is null)
            return;

        _posX = x;
        _posY = y;
        _corner = corner;

        _member = null;
        _user = user;

        _profile = await _user.FetchProfileAsync();
        if (_profile is null)
            return;

        _hidden = false;
        _needsPositioning = true;
        _needsDetailLoad = true;

        StateHasChanged();
    }

    public async Task OpenAsync(PlanetMember member, int x, int y, string corner = "bottomLeft")
    {
        if (member?.User is null)
            return;

        _posX = x;
        _posY = y;
        _corner = corner;

        _member = member;
        _user = member.User;

        _profile =  await _user.FetchProfileAsync();
        if (_profile is null)
            return;

        _hidden = false;
        _needsPositioning = true;
        _needsDetailLoad = true;

        StateHasChanged();
    }

    

    private void Close()
    {
        _hidden = true;
        StateHasChanged();
    }

    private Task OnKeyDown(KeyboardListener.KeyboardEvent e)
    {
        if (e.Key == "Escape")
            Close();

        return Task.CompletedTask;
    }
}