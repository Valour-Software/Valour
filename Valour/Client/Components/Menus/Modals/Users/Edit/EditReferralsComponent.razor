@using System.Web
@inject IJSRuntime JsRuntime
@inject ValourClient Client

<div class="settings-page">

    @* ===== Referral Link ===== *@
    <div class="editor-section">
        <h3 class="editor-section-title">
            <i class="bi bi-link-45deg"></i>
            Your Referral Link
        </h3>

        <div class="link-card">
            <span class="link-text">@_link</span>
            <VButton Variant="primary" Size="sm" Icon="clipboard" OnClick="@OnClickCopyLink">Copy</VButton>
        </div>
        <p class="helper-text">Share this link with friends — you earn rewards when they join.</p>
    </div>

    @* ===== Referrals ===== *@
    <div class="editor-section">
        <h3 class="editor-section-title">
            <i class="bi bi-people"></i>
            Your Referrals
        </h3>

        @if (_referrals is null)
        {
            <p class="helper-text">Loading referrals...</p>
        }
        else if (_referrals.Count == 0)
        {
            <p class="helper-text">No referrals yet. Share your link to get started!</p>
        }
        else
        {
            <div class="referral-table-wrapper">
                <table class="v-table">
                    <thead>
                    <tr>
                        <th>Name</th>
                        <th>Time</th>
                        <th>Reward</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var referral in _referrals)
                    {
                        <tr>
                            <td>@referral.Name</td>
                            <td>@referral.Time.ToShortDateString() @referral.Time.ToShortTimeString()</td>
                            <td>@Math.Round(referral.Reward, 2)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>


@code {
    private string _link;
    private List<ReferralDataModel> _referrals;

    protected override async Task OnInitializedAsync()
    {
        _link = $"{ClientHosts.AppBaseUrl}/register/referral/" + HttpUtility.UrlEncode(Client.Me.NameAndTag);
        var result = await Client.GetMyReferralsAsync();
        _referrals = result.Data;
        StateHasChanged();
    }
    
    private async Task OnClickCopyLink()
    {
        await JsRuntime.InvokeVoidAsync("clipboardCopy.copyText", _link);
        ToastContainer.Instance.AddToast(new ToastData("Copied!", "Referral link copied to clipboard", ToastProgressState.Success));
    }

}