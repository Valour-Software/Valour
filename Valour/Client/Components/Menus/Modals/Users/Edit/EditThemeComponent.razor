@inject IJSRuntime JsRuntime
@inject ValourClient Client
@inject ThemeService ThemeService

@using System.Net.Http.Headers
@using Valour.Shared.Extensions
@using Valour.Client.Utility
@using Valour.Sdk.ModelLogic.QueryEngines
@using Valour.Shared.Models.Themes

@if (_editingTheme is not null)
{
    <div class="settings-page wide theme-editor-page">
        <div class="editor-section theme-editor-hero">
            <h3 class="editor-section-title">
                <i class="bi bi-palette"></i>
                Theme Editor
            </h3>
            <p class="helper-text">Preview changes live while you tune surfaces, semantic colors, fonts, assets, and custom CSS.</p>
        </div>

        <div class="editor-section">
            <h3 class="editor-section-title">
                <i class="bi bi-image"></i>
                Banner
            </h3>

            @if (_editingTheme.HasCustomBanner && _editingTheme.HasAnimatedBanner && _blobUrl is null)
            {
                <style>
                    .theme-img-@_editingTheme.Id:hover {
                        background-image: url(@_editingTheme.GetBannerUrl(ThemeBannerFormat.WebpAnimated)), url(@_editingTheme.GetBannerUrl(ThemeBannerFormat.Webp)), url(_content/Valour.Client/media/image-not-found.webp) !important;
                    }
                </style>
            }

            <div class="theme-banner-row">
                @if (_blobUrl is not null)
                {
                    <label class="theme-img theme-img-@_editingTheme.Id" for="banner-upload" style="background-image: url(@_blobUrl)"></label>
                }
                else if (_editingTheme.HasCustomBanner)
                {
                    <label class="theme-img theme-img-@_editingTheme.Id" for="banner-upload" style="background-image: url(@_editingTheme.GetBannerUrl(ThemeBannerFormat.Webp)), url(_content/Valour.Client/media/image-not-found.webp)"></label>
                }
                else
                {
                    <label class="theme-img victor-placeholder" for="banner-upload" style="background-color: @_editingTheme.MainColor1">
                        <Victor Style="max-height: 80%; padding: 5px; padding-top: 10px;" Color="@_editingTheme.PastelCyan" />
                    </label>
                }

                <div class="theme-banner-copy">
                    <label for="banner-upload" class="v-btn secondary">
                        <i class="bi bi-upload"></i>
                        Upload Banner
                    </label>
                    <p class="helper-text">PNG, JPG, GIF, or WEBP. Suggested size: 600x300px.</p>
                </div>
            </div>

            <div class="hidden-input">
                <InputFile OnChange="@LoadFiles" accept=".png,.jpg,.jpeg,.gif,.webp" id="banner-upload"></InputFile>
            </div>
        </div>

        <div class="editor-section">
            <h3 class="editor-section-title">
                <i class="bi bi-card-text"></i>
                Details
            </h3>

            <div class="form-group">
                <label>Name</label>
                <input class="v-input" @bind-value="@_editingTheme.Name" />
            </div>

            <div class="form-group">
                <label>Description</label>
                <InputTextArea @bind-Value="@_editingTheme.Description" class="v-input" rows="4"></InputTextArea>
            </div>

            <div class="toggle-item">
                <div class="toggle-header">
                    <span class="toggle-title">Publishing</span>
                    <span class="@GetPublishedBadgeClass()">@(_editingTheme.Published ? "Published" : "Private")</span>
                </div>
                <p class="toggle-description">Published themes are visible to other users in the theme browser.</p>
                <div class="actions">
                    @if (_editingTheme.Published)
                    {
                        <VButton Variant="danger" OnClick="@(() => SetPublished(false))">Switch to Private</VButton>
                    }
                    else
                    {
                        <VButton Variant="primary" OnClick="@(() => SetPublished(true))">Publish Theme</VButton>
                    }
                </div>
            </div>
        </div>

        <div class="editor-section">
            <h3 class="editor-section-title">
                <i class="bi bi-fonts"></i>
                Typography & Radius
            </h3>

            <div class="form-group">
                <label>App Font</label>
                <input class="v-input" value="@_editingTheme.FontFamily" @oninput="@OnChangeFontFamily" />
                <p class="helper-text">Use a normal CSS font stack, or choose an uploaded font below.</p>
            </div>

            @if (FontAssets.Any())
            {
                <div class="form-group">
                    <label>Uploaded Fonts</label>
                    <select class="v-input" @onchange="@OnFontAssetSelected">
                        <option value="">Choose uploaded font...</option>
                        @foreach (var asset in FontAssets)
                        {
                            <option value="@asset.Name">@($"theme-font-{asset.Name}")</option>
                        }
                    </select>
                </div>
            }

            <div class="form-group">
                <label>Rounding Scale</label>
                <div class="radius-grid">
                    <input class="v-input" value="@_editingTheme.RadiusXs" @oninput="@OnChangeRadiusXs" placeholder="xs" />
                    <input class="v-input" value="@_editingTheme.RadiusSm" @oninput="@OnChangeRadiusSm" placeholder="sm" />
                    <input class="v-input" value="@_editingTheme.RadiusMd" @oninput="@OnChangeRadiusMd" placeholder="md" />
                    <input class="v-input" value="@_editingTheme.RadiusLg" @oninput="@OnChangeRadiusLg" placeholder="lg" />
                    <input class="v-input" value="@_editingTheme.RadiusXl" @oninput="@OnChangeRadiusXl" placeholder="xl" />
                    <input class="v-input" value="@_editingTheme.RadiusFull" @oninput="@OnChangeRadiusFull" placeholder="full" />
                </div>
            </div>
        </div>

        <div class="editor-section">
            <h3 class="editor-section-title">
                <i class="bi bi-droplet-half"></i>
                Text Colors
            </h3>

            <section class="color-section">
                <div class="color-pill">
                    <span>Text</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.FontColor" OnColorChange="@OnChangeFontColor"/>
                </div>
                <div class="color-pill">
                    <span>Muted Text</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.FontAltColor" OnColorChange="@OnChangeFontAltColor"/>
                </div>
                <div class="color-pill">
                    <span>Links</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.LinkColor" OnColorChange="@OnChangeLinkColor"/>
                </div>
            </section>
        </div>

        <div class="editor-section">
            <h3 class="editor-section-title">
                <i class="bi bi-layers"></i>
                Surfaces
            </h3>
            <p class="helper-text">These drive <code>--main-1</code> through <code>--main-5</code>, including the new fifth surface slot.</p>

            <section class="color-section">
                <div class="color-pill">
                    <span>Surface 1</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.MainColor1" OnColorChange="@OnChangeMainColor1"/>
                </div>
                <div class="color-pill">
                    <span>Surface 2</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.MainColor2" OnColorChange="@OnChangeMainColor2"/>
                </div>
                <div class="color-pill">
                    <span>Surface 3</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.MainColor3" OnColorChange="@OnChangeMainColor3"/>
                </div>
                <div class="color-pill">
                    <span>Surface 4</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.MainColor4" OnColorChange="@OnChangeMainColor4"/>
                </div>
                <div class="color-pill">
                    <span>Surface 5</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.MainColor5" OnColorChange="@OnChangeMainColor5"/>
                </div>
                <div class="color-pill">
                    <span>Tint</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.TintColor" OnColorChange="@OnChangeTintColor"/>
                </div>
            </section>
        </div>

        <div class="editor-section">
            <h3 class="editor-section-title">
                <i class="bi bi-stars"></i>
                Semantic Colors
            </h3>
            <p class="helper-text">These map to the newer app tokens: primary, secondary, accent, danger, staff, and bot colors.</p>

            <section class="color-section">
                <div class="color-pill">
                    <span>Primary</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.VibrantCyan" OnColorChange="@OnChangeVibrantColor3"/>
                </div>
                <div class="color-pill">
                    <span>Secondary</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.VibrantPurple" OnColorChange="@OnChangeVibrantColor1"/>
                </div>
                <div class="color-pill">
                    <span>Accent</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.PastelCyanPurple" OnColorChange="@OnChangePastelColor2"/>
                </div>
                <div class="color-pill">
                    <span>Danger</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.PastelRed" OnColorChange="@OnChangePastelColorDanger"/>
                </div>
                <div class="color-pill">
                    <span>Staff</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.VibrantCyan" OnColorChange="@OnChangeVibrantColor3"/>
                </div>
                <div class="color-pill">
                    <span>Bot</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.VibrantPurple" OnColorChange="@OnChangeVibrantColor1"/>
                </div>
            </section>
        </div>

        <div class="editor-section">
            <h3 class="editor-section-title">
                <i class="bi bi-palette2"></i>
                Legacy Palette Aliases
            </h3>
            <p class="helper-text">These keep older <code>--v-*</code> and <code>--p-*</code> theme variables editable.</p>

            <section class="color-section">
                <div class="color-pill">
                    <span>Vibrant Blue</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.VibrantBlue" OnColorChange="@OnChangeVibrantColor2"/>
                </div>
                <div class="color-pill">
                    <span>Pastel Cyan</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.PastelCyan" OnColorChange="@OnChangePastelColor1"/>
                </div>
                <div class="color-pill">
                    <span>Pastel Purple</span>
                    <ColorPickerComponent UseAsButton="true" ButtonClass="pickr-button" StartColor="@_editingTheme.PastelPurple" OnColorChange="@OnChangePastelColor3"/>
                </div>
            </section>
        </div>

        <div class="editor-section">
            <h3 class="editor-section-title">
                <i class="bi bi-filetype-css"></i>
                Custom CSS
            </h3>

            <div class="form-group">
                <InputTextArea @bind-Value="@_editingTheme.CustomCss" class="v-input custom-css-input" rows="8"></InputTextArea>
                <p class="helper-text">Custom CSS is sanitized before preview and save. Use uploaded assets with the generated CSS variables below.</p>
                <div class="actions">
                    <VButton Variant="secondary" OnClick="@OnCssChange">Apply CSS to Preview</VButton>
                </div>
            </div>
        </div>

        <div class="editor-section">
            <h3 class="editor-section-title">
                <i class="bi bi-folder2-open"></i>
                Theme Assets
            </h3>
            <p class="helper-text">Upload images or fonts. Images expose <code>var(--theme-asset-name)</code>; fonts expose <code>"theme-font-name"</code>.</p>

            @if (_themeAssets?.Any() == true)
            {
                <div class="assets-list">
                    @foreach (var asset in _themeAssets)
                    {
                        <div class="asset-row">
                            @if (asset.AssetType == "font")
                            {
                                <div class="asset-icon">
                                    <i class="bi bi-fonts"></i>
                                </div>
                                <div class="asset-info">
                                    <strong>@asset.Name</strong>
                                    <code>font-family: "theme-font-@asset.Name"</code>
                                </div>
                                <VButton Variant="secondary" Size="sm" OnClick="@(() => UseFontAsset(asset))">Use Font</VButton>
                            }
                            else
                            {
                                <img src="@asset.Url" alt="@asset.Name" class="asset-preview" />
                                <div class="asset-info">
                                    <strong>@asset.Name</strong>
                                    <code>var(--theme-asset-@asset.Name)</code>
                                </div>
                            }
                            <VButton Variant="danger" Size="sm" Icon="trash" Title="Delete asset" OnClick="@(() => DeleteAssetAsync(asset))" />
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="helper-text">No assets uploaded yet.</p>
            }

            @if (_editingTheme.Id != 0)
            {
                <div class="asset-upload-row">
                    <input class="v-input asset-name-input" @bind="_newAssetName" placeholder="Asset name, e.g. background" />
                    <VButton Variant="secondary" OnClick="@OpenAssetPickerAsync">Choose File</VButton>
                    <span class="selected-file" title="@(_assetFileName ?? "No file selected")">@(_assetFileName ?? "No file selected")</span>
                    <input id="@_assetUploadInputId" type="file" class="hidden-native-input" accept=".png,.jpg,.jpeg,.webp,.gif,.woff2,.woff,.ttf,.otf" />
                </div>
                <div class="actions">
                    <VButton Variant="primary" Disabled="@_uploadingAsset" OnClick="@UploadAssetAsync">
                        @(_uploadingAsset ? "Uploading..." : "Upload Asset")
                    </VButton>
                </div>
                @if (!string.IsNullOrEmpty(_assetError))
                {
                    <p class="helper-text error-text">@_assetError</p>
                }
            }
            else
            {
                <p class="helper-text">Save the theme first to upload assets.</p>
            }
        </div>

        <div class="editor-section">
            <div class="actions editor-actions">
                <VButton Variant="danger" Size="lg" OnClick="@CancelEdit">Cancel Changes</VButton>
                <VButton Variant="primary" Size="lg" OnClick="@ConfirmChangesAsync">Save Theme</VButton>
            </div>
            <ResultLabel Result="@_editingResult"/>
        </div>
    </div>
}
else
{
    <div class="settings-page wide theme-home-page">
        <div class="editor-section">
            <h3 class="editor-section-title">
                <i class="bi bi-stars"></i>
                Current Theme
            </h3>

            <div class="current-theme-section">
                <ThemeCard Theme="@ThemeComponent.Instance.CurrentTheme.ToMeta()" />
                <button type="button" class="create-theme-card" @onclick="@EnterEditorNewTheme">
                    <span class="create-theme-icon">
                        <i class="bi bi-plus-circle"></i>
                    </span>
                    <span class="create-theme-title">Create New Theme</span>
                    <span class="create-theme-description">Start from your current theme and preview changes live.</span>
                    <span class="create-theme-btn">
                        <i class="bi bi-palette"></i>
                        Open Editor
                    </span>
                </button>
            </div>

            @if (ThemeComponent.Instance.CurrentTheme != Theme.Default)
            {
                <div class="actions">
                    <VButton Variant="secondary" OnClick="@RevertThemeAsync">Revert to Default Theme</VButton>
                </div>
            }
        </div>

        <div class="editor-section">
            <h3 class="editor-section-title">
                <i class="bi bi-compass"></i>
                Popular Themes
            </h3>
            <LargeSearch Placeholder="Search themes..."
                         DebounceMs="300"
                         OnSearchChanged="@OnSearchChangeAsync"
                         OnSearchCleared="@OnSearchCleared" />
            <div class="carousel-section">
                <Carousel TItem="Valour.Sdk.Models.Themes.ThemeMeta"
                          @ref="_popularCarousel"
                          Items="@_popularThemesList"
                          Breakpoints="@_themeBreakpoints"
                          GapPx="16"
                          TransitionMs="300"
                          MinItemWidth="200"
                          MaxItemWidth="300"
                          ItemPadding="8"
                          IsLoading="@_isLoadingPopular"
                          EmptyMessage="No popular themes found">
                    <ItemTemplate>
                        <ThemeCard Theme="@context" Editor="@this" />
                    </ItemTemplate>
                </Carousel>
            </div>
        </div>

        <div class="editor-section">
            <h3 class="editor-section-title">
                <i class="bi bi-person-workspace"></i>
                My Themes
            </h3>
            <div class="carousel-section">
                <Carousel TItem="Valour.Sdk.Models.Themes.ThemeMeta"
                          @ref="@_myCarousel"
                          Items="@_myThemes"
                          Breakpoints="@_themeBreakpoints"
                          GapPx="16"
                          TransitionMs="300"
                          MinItemWidth="200"
                          MaxItemWidth="300"
                          ItemPadding="8"
                          IsLoading="@_isLoadingMy"
                          EmptyMessage="You haven't created any themes yet">
                    <ItemTemplate>
                        <ThemeCard Theme="@context" Editor="@this" />
                    </ItemTemplate>
                </Carousel>
            </div>
        </div>
    </div>
}

@code {
    private Theme _backupTheme;
    private Theme _editingTheme;
    
    private Carousel<Valour.Sdk.Models.Themes.ThemeMeta> _popularCarousel;
    private Carousel<Valour.Sdk.Models.Themes.ThemeMeta> _myCarousel;

    private ThemeMetaQueryEngine _popularThemes;
    private int _popularThemeCount = 0;
    private List<Valour.Sdk.Models.Themes.ThemeMeta> _popularThemesList = new();
    private bool _isLoadingPopular = false;
    
    private List<Valour.Sdk.Models.Themes.ThemeMeta> _myThemes;
    private bool _isLoadingMy = false;
    
    private readonly List<Breakpoint> _themeBreakpoints = new()
    {
        new() { MinWidth = 0, Visible = 1 },      // Mobile: 1 item
        new() { MinWidth = 600, Visible = 2 },    // Tablet: 2 items
        new() { MinWidth = 900, Visible = 3 },    // Desktop: 3 items
        new() { MinWidth = 1200, Visible = 4 }    // Large: 4 items
    };

    private TaskResult<Theme>? _editingResult = null;

    private IBrowserFile _uploadedImage = null;
    private byte[] _uploadedImageBytes = null;

    private string _blobUrl;

    // Theme asset fields
    private List<ThemeAssetInfo> _themeAssets = new();
    private string _newAssetName;
    private string _assetFileName;
    private string _assetError;
    private bool _uploadingAsset;
    private readonly string _assetUploadInputId = $"theme-asset-upload-{System.Guid.NewGuid():N}";
    private IEnumerable<ThemeAssetInfo> FontAssets =>
        _themeAssets?.Where(asset => asset.AssetType == "font") ?? Enumerable.Empty<ThemeAssetInfo>();

    private string GetPublishedBadgeClass() =>
        _editingTheme?.Published == true ? "status-badge enabled" : "status-badge";

    protected override async Task OnInitializedAsync()
    {
        await GetAllThemes();
        ThemeComponent.OnThemeChanged += ThemeChangedHandler;
        StateHasChanged();
    }
    
     
    private void ThemeChangedHandler()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadFiles(InputFileChangeEventArgs e)
    {
        _uploadedImage = e.File;
        
        using MemoryStream ms = new();
        var fileStream = e.File.OpenReadStream();
        await fileStream.CopyToAsync(ms);
        _uploadedImageBytes = ms.ToArray();
        
        _blobUrl = await JsRuntime.InvokeAsync<string>("createBlob", _uploadedImageBytes, e.File.ContentType);
        
        StateHasChanged();
    }
   


    private async Task OnSearchChangeAsync(string searchValue)
    {
        _isLoadingPopular = true;
        StateHasChanged();

        try
        {
            // Use proper ModelQueryEngine API with QueryOptions
            _popularThemes.SetFilter("search", searchValue, apply: true);

            // Reload themes with new filter
            _popularThemesList.Clear();
            _popularThemeCount = await _popularThemes.GetTotalCountAsync();

            // Load themes in batches
            int pageSize = 50;
            int currentPage = 0;

            while (true)
            {
                var page = await _popularThemes.GetPageAsync(currentPage, pageSize);
                if (page == null || page.Count == 0)
                    break;

                _popularThemesList.AddRange(page);

                if (page.Count < pageSize)
                    break;

                currentPage++;
            }
        }
        finally
        {
            _isLoadingPopular = false;
            StateHasChanged();

            if (_popularCarousel is not null)
                await _popularCarousel.Reset();
        }
    }

    private async Task OnSearchCleared()
    {
        _isLoadingPopular = true;
        StateHasChanged();

        try
        {
            // Clear the search filter
            _popularThemes.SetFilter("search", null, apply: true);

            // Reload themes without filter
            _popularThemesList.Clear();
            _popularThemeCount = await _popularThemes.GetTotalCountAsync();

            // Load themes in batches
            int pageSize = 50;
            int currentPage = 0;

            while (true)
            {
                var page = await _popularThemes.GetPageAsync(currentPage, pageSize);
                if (page == null || page.Count == 0)
                    break;

                _popularThemesList.AddRange(page);

                if (page.Count < pageSize)
                    break;

                currentPage++;
            }
        }
        finally
        {
            _isLoadingPopular = false;
            StateHasChanged();

            if (_popularCarousel is not null)
                await _popularCarousel.Reset();
        }
    }
    
    private void OnCssChange()
    {
        ThemeComponent.Instance.Refresh();
        Client.Logger.Log<EditThemeComponent>("Custom CSS updated.", "cyan");
    }

    private void OnChangeFontFamily(ChangeEventArgs e)
    {
        _editingTheme.FontFamily = e.Value?.ToString();
        ThemeComponent.Instance.Refresh();
    }

    private void OnChangeRadiusXs(ChangeEventArgs e) => UpdateRadius(e, value => _editingTheme.RadiusXs = value);
    private void OnChangeRadiusSm(ChangeEventArgs e) => UpdateRadius(e, value => _editingTheme.RadiusSm = value);
    private void OnChangeRadiusMd(ChangeEventArgs e) => UpdateRadius(e, value => _editingTheme.RadiusMd = value);
    private void OnChangeRadiusLg(ChangeEventArgs e) => UpdateRadius(e, value => _editingTheme.RadiusLg = value);
    private void OnChangeRadiusXl(ChangeEventArgs e) => UpdateRadius(e, value => _editingTheme.RadiusXl = value);
    private void OnChangeRadiusFull(ChangeEventArgs e) => UpdateRadius(e, value => _editingTheme.RadiusFull = value);

    private void UpdateRadius(ChangeEventArgs e, Action<string> setRadius)
    {
        setRadius(e.Value?.ToString());
        ThemeComponent.Instance.Refresh();
    }
    
    private async Task SetPublished(bool published)
    {
        _editingTheme.Published = published;
        _myThemes = await ThemeService.GetMyThemes();
        StateHasChanged();
    }

    private async Task RevertThemeAsync()
    {
        await ThemeComponent.Instance.UninstallThemeAsync();
    }


    public async Task OpenEditorWithTheme(Theme theme)
    {
        _backupTheme = ThemeComponent.Instance.CurrentTheme;
        _editingTheme = theme;
        _editingTheme.FontFamily = ISharedTheme.NormalizeFontFamily(_editingTheme.FontFamily);
        NormalizeEditingThemeRadii();
        _assetFileName = null;
        _assetError = null;

        ThemeComponent.Instance.CurrentTheme = theme;

        Client.Logger.Log<EditThemeComponent>($"Entering editor for theme: {theme.Name}", "cyan");

        if (theme.Id != 0)
        {
            await LoadThemeAssetsAsync(theme.Id);
        }
        else
        {
            _themeAssets = theme.Assets ?? new();
            SyncThemeAssetsToPreview();
        }

        StateHasChanged();
    }

    private void EnterEditorNewTheme()
    {
        _backupTheme = ThemeComponent.Instance.CurrentTheme;
        _assetFileName = null;
        _assetError = null;
        
        _editingTheme = new Theme(Client);
        ThemeComponent.Instance.CurrentTheme.CopyAllTo(_editingTheme);
        _editingTheme.Id = 0;
        _editingTheme.Name = "New Theme";
        _editingTheme.Description = "A new theme!";
        _editingTheme.FontFamily = ISharedTheme.NormalizeFontFamily(_editingTheme.FontFamily);
        NormalizeEditingThemeRadii();
        _themeAssets = new();
        
        ThemeComponent.Instance.CurrentTheme = _editingTheme;
        SyncThemeAssetsToPreview();
        
        Client.Logger.Log<EditThemeComponent>("Entering editor for new theme.", "cyan");
        
        StateHasChanged();
    }

    private void NormalizeEditingThemeRadii()
    {
        _editingTheme.RadiusXs = ISharedTheme.NormalizeRadius(_editingTheme.RadiusXs, ISharedTheme.DefaultRadiusXs);
        _editingTheme.RadiusSm = ISharedTheme.NormalizeRadius(_editingTheme.RadiusSm, ISharedTheme.DefaultRadiusSm);
        _editingTheme.RadiusMd = ISharedTheme.NormalizeRadius(_editingTheme.RadiusMd, ISharedTheme.DefaultRadiusMd);
        _editingTheme.RadiusLg = ISharedTheme.NormalizeRadius(_editingTheme.RadiusLg, ISharedTheme.DefaultRadiusLg);
        _editingTheme.RadiusXl = ISharedTheme.NormalizeRadius(_editingTheme.RadiusXl, ISharedTheme.DefaultRadiusXl);
        _editingTheme.RadiusFull = ISharedTheme.NormalizeRadius(_editingTheme.RadiusFull, ISharedTheme.DefaultRadiusFull);
    }
    
    private void CancelEdit()
    {
        _editingTheme = null;
        _assetFileName = null;
        _assetError = null;
        Client.Logger.Log<EditThemeComponent>("Cancelled theme editing.", "cyan");
        
        ThemeComponent.Instance.CurrentTheme = _backupTheme;
        
        ThemeComponent.Instance.Refresh();
        
        StateHasChanged();
    }

    private async Task UploadBannerIfNeededAsync()
    {
        if (_uploadedImage is null)
            return;

        if (_uploadedImage.Size > 10240000)
            return;
        
        using var ms = new MemoryStream(_uploadedImageBytes);
        var streamContent = new StreamContent(ms);
        var content = new MultipartFormDataContent();
        streamContent.Headers.ContentType = new MediaTypeHeaderValue(_uploadedImage.ContentType);
        content.Add(streamContent, _uploadedImage.Name, _uploadedImage.Name);
        
        var result = await Client.PrimaryNode.PostMultipartDataWithResponse<string>($"upload/themeBanner/{_editingTheme.Id}", content);
        if (!result.Success)
        {
            Console.WriteLine("Failed to upload banner: " + result.Message);
        }

        _blobUrl = null;
    }

    private async Task ConfirmChangesAsync()
    {
        if (_editingTheme is null)
            return;

        // Prevent duplicate names for new themes only
        if (_editingTheme.Id == 0 && _myThemes != null && _myThemes.Any(t => t.Name == _editingTheme.Name))
        {
            _editingResult = new TaskResult<Theme>(false, "You already have a theme with that name.");
            StateHasChanged();
            return;
        }

        if (_editingTheme.Id == 0)
        {
            // New theme
            _editingResult = await _editingTheme.CreateAsync();
            await GetAllThemes();
            StateHasChanged();
        }
        else
        {
            // Existing theme
            _editingResult = await _editingTheme.UpdateAsync();
            await GetAllThemes();
            StateHasChanged();
        }

        if (!_editingResult.Value.Success)
        {
            Client.Logger.Log<EditThemeComponent>($"Failed to save theme: {_editingResult.Value.Message}", "red");
        }
        else
        {
            _editingTheme = _editingResult.Value.Data;
            
            await UploadBannerIfNeededAsync();
            
            _editingTheme = null;
            StateHasChanged();
        }
    }

