@using System.Net.Http.Headers
@using Valour.Client.Utility
@using Valour.Shared.Models
@inject ValourClient Client

<div class="settings-page">
    <div class="editor-section">
        <h3 class="editor-section-title">
            <i class="bi bi-globe2"></i>
            Planet Info
        </h3>
        <p class="helper-text top-help">Edit your planet's name, tags, and primary chat channel</p>

        <div class="form-group">
            <label>Name</label>
            <input class="v-input" placeholder="Planet Name" @bind-value="_nameValue" maxlength="32" />
        </div>

        <div class="form-group">
            <label>Primary Chat Channel</label>
            <CustomDropdown TItem="Channel"
                            Items="_chatChannels"
                            InitialItem="_selectedPrimaryChannel"
                            SelectedItemChanged="OnPrimaryChannelChanged"
                            ItemTemplate="ChannelFragments.ChannelPill"
                            Placeholder="Select Primary Channel" />
        </div>

        <ResultLabel Result="@_mainResult" />

        <SearchTagFilterComponent InitialTags="Planet.Tags?.Select(t => t.Id).ToList() ?? new List<long>()" OnTagSelectToPlanet="HandleTagSelection"
                   OnTagRemoveToPlanet="HandleTagRemoved" ShowCreateButton="true"/>

        <div class="actions">
            <button class="v-btn primary" @onclick="OnSaveChanges">Save Changes</button>
        </div>
    </div>

    <div class="editor-section">
        <h3 class="editor-section-title">
            <i class="bi bi-link-45deg"></i>
            Vanity URL
        </h3>

        <p class="toggle-description">
            Claim a unique name that identifies this planet in public links — the planet page,
            the wiki, and more. Lowercase letters, numbers, and dashes; 3-@ISharedPlanet.MaxVanityLength characters.
        </p>

        <div class="vanity-row">
            <input class="v-input vanity-input" maxlength="@ISharedPlanet.MaxVanityLength"
                   placeholder="my-community" spellcheck="false"
                   value="@_vanityValue" @oninput="OnVanityInput"/>
            <button class="v-btn primary" disabled="@(!_vanityCanSave)" @onclick="SaveVanityAsync">Save</button>
            @if (!string.IsNullOrWhiteSpace(Planet.Vanity))
            {
                <button class="v-btn" @onclick="ClearVanityAsync">Clear</button>
            }
        </div>

        @if (_vanityStatus is not null)
        {
            <p class="vanity-status @(_vanityAvailable ? "ok" : "bad")">@_vanityStatus</p>
        }
    </div>

    <div class="editor-section">
        <h3 class="editor-section-title">
            <i class="bi bi-rocket-takeoff-fill"></i>
            Threads
        </h3>

        <div class="toggle-item">
            <div class="toggle-header">
                <span class="toggle-title">Enable Threads</span>
                <label class="switch">
                    <input type="checkbox" @oninput="OnCheckEnableThreads" checked="@_enableThreadsValue" />
                    <span class="slider round"></span>
                </label>
            </div>
            <p class="toggle-description">Give this planet a Reddit-style threads feed where members can post and comment</p>
            <ResultLabel Result="@_enableThreadsResult" />
        </div>

        <div class="toggle-item">
            <div class="toggle-header">
                <span class="toggle-title">Public Threads</span>
                <label class="switch">
                    <input type="checkbox" @oninput="OnCheckPublicThreads" checked="@_publicThreadsValue" disabled="@(!_enableThreadsValue)" />
                    <span class="slider round"></span>
                </label>
            </div>
            <p class="toggle-description">Allow anyone on the web to browse this planet's threads without an account</p>
            <ResultLabel Result="@_publicThreadsResult" />
        </div>
    </div>

    <div class="editor-section">
        <h3 class="editor-section-title">
            <i class="bi bi-image"></i>
            Appearance
        </h3>
        <div class="appearance-split">
            <div class="options">
                <div>
                    <button class="v-btn primary" onclick="document.getElementById('icon-upload').click()">Upload Icon</button>
                    <p class="helper-text">Upload a Planet Icon (max 8MB, square)</p>
                    <ResultLabel Result="@_iconResult"/>
                    <InputFile @ref="_iconFileInput"
                               id="icon-upload"
                               OnChange="LoadIconFiles"
                               style="display:none"
                               accept=".png,.jpg,.jpeg,.gif,.webp"/>
                </div>
                
                <div>
                    <button class="v-btn primary" onclick="document.getElementById('bg-upload').click()">Upload Background</button>
                    <p class="helper-text">Upload a Planet Background (max 10MB, 300x400px)</p>
                    <ResultLabel Result="@_bgResult"/>
                    <InputFile @ref="_bgFileInput"
                               id="bg-upload"
                               OnChange="LoadBackgroundFiles"
                               style="display:none"
                               accept=".png,.jpg,.jpeg,.gif,.webp"/>
                </div>
            </div>
            <div class="card-preview">
                <DiscoveryPlanetCard HideActions="true" PlanetInfo="@Planet.ToListInfo()" />
            </div>
        </div>
        
       
    </div>
</div>

@code {
    [Parameter]
    public Planet Planet { get; set; }

    private string _nameValue;

    private ITaskResult _mainResult;
    private ITaskResult _iconResult;
    private ITaskResult _bgResult;

    private InputFile _iconFileInput;
    private InputFile _bgFileInput;

    private List<Channel> _chatChannels = new();
    private Channel? _selectedPrimaryChannel;

    private bool _enableThreadsValue;
    private ITaskResult _enableThreadsResult;
    private bool _publicThreadsValue;
    private ITaskResult _publicThreadsResult;

    protected override Task OnInitializedAsync()
    {
        _nameValue = Planet.Name;
        _chatChannels = Planet.Channels.Where(c => c.ChannelType == ChannelTypeEnum.PlanetChat).ToList();
        _selectedPrimaryChannel = Planet.PrimaryChatChannel;
        _vanityValue = Planet.Vanity ?? string.Empty;
        _enableThreadsValue = Planet.EnableThreads;
        _publicThreadsValue = Planet.PublicThreads;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private string _vanityValue = string.Empty;
    private bool _vanityAvailable;
    private bool _vanityCanSave;
    private string _vanityStatus;
    private CancellationTokenSource _vanityCts;

    private void OnVanityInput(ChangeEventArgs e)
    {
        _vanityValue = (e.Value?.ToString() ?? string.Empty).ToLowerInvariant();
        _vanityCanSave = false;
        _ = DebounceVanityCheckAsync();
    }

    private async Task DebounceVanityCheckAsync()
    {
        _vanityCts?.Cancel();
        _vanityCts = new CancellationTokenSource();
        var token = _vanityCts.Token;

        if (string.IsNullOrWhiteSpace(_vanityValue) || _vanityValue == Planet.Vanity)
        {
            _vanityStatus = null;
            return;
        }

        // Cheap local validation before hitting the server
        var localCheck = VanityUtils.ValidateVanity(_vanityValue);
        if (!localCheck.Success)
        {
            _vanityAvailable = false;
            _vanityStatus = localCheck.Message;
            StateHasChanged();
            return;
        }

        try
        {
            await Task.Delay(400, token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        var result = await Client.PlanetService.CheckVanityAvailableAsync(Planet, _vanityValue);
        if (token.IsCancellationRequested)
            return;

        _vanityAvailable = result.Success;
        _vanityCanSave = result.Success;
        _vanityStatus = result.Success ? "Available!" : result.Message;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveVanityAsync()
    {
        var result = await Client.PlanetService.SetVanityAsync(Planet, _vanityValue);
        if (!result.Success)
        {
            _vanityAvailable = false;
            _vanityStatus = result.Message;
            StateHasChanged();
            return;
        }

        Planet.Vanity = _vanityValue;
        _vanityCanSave = false;
        _vanityStatus = "Saved!";
        _vanityAvailable = true;
        StateHasChanged();
    }

    private async Task ClearVanityAsync()
    {
        var result = await Client.PlanetService.SetVanityAsync(Planet, null);
        if (!result.Success)
        {
            _vanityStatus = result.Message;
            _vanityAvailable = false;
            StateHasChanged();
            return;
        }

        Planet.Vanity = null;
        _vanityValue = string.Empty;
        _vanityStatus = null;
        _vanityCanSave = false;
        StateHasChanged();
    }

    private async Task OnCheckEnableThreads()
    {
        _enableThreadsValue = !_enableThreadsValue;

        Planet.EnableThreads = _enableThreadsValue;
        _enableThreadsResult = await Planet.UpdateAsync();

        if (!_enableThreadsResult.Success)
        {
            _enableThreadsValue = !_enableThreadsValue;
            Planet.EnableThreads = _enableThreadsValue;
        }

        StateHasChanged();
    }

    private async Task OnCheckPublicThreads()
    {
        _publicThreadsValue = !_publicThreadsValue;

        Planet.PublicThreads = _publicThreadsValue;
        _publicThreadsResult = await Planet.UpdateAsync();

        if (!_publicThreadsResult.Success)
        {
            _publicThreadsValue = !_publicThreadsValue;
            Planet.PublicThreads = _publicThreadsValue;
        }

        StateHasChanged();
    }

    private Task OnPrimaryChannelChanged(Channel channel)
    {
        _selectedPrimaryChannel = channel;
        return Task.CompletedTask;
    }

    private async Task LoadIconFiles(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file == null)
        {
            _iconResult = new TaskResult(false, "Could not load file as an image.");
            StateHasChanged();
            return;
        }

        if (file.Size > 8 * 1024 * 1024)
        {
            _iconResult = new TaskResult(false, "Max planet image size is 8MB.");
            StateHasChanged();
            return;
        }

        byte[] data = new byte[file.Size];
        await file.OpenReadStream(8 * 1024 * 1024).ReadAsync(data);

        var content = new MultipartFormDataContent();
        var arrContent = new ByteArrayContent(data);
        arrContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);

        content.Add(arrContent, file.Name, file.Name);

        var result = await Planet.Node.PostMultipartDataWithResponse<string>($"upload/planet/{Planet.Id}", content);
        _iconResult = result;

        StateHasChanged();
    }
    
    private async Task LoadBackgroundFiles(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file == null)
        {
            _iconResult = new TaskResult(false, "Could not load file as an image.");
            StateHasChanged();
            return;
        }

        if (file.Size > 10 * 1024 * 1024)
        {
            _iconResult = new TaskResult(false, "Max planet background size is 10MB.");
            StateHasChanged();
            return;
        }

        byte[] data = new byte[file.Size];
        await file.OpenReadStream(10 * 1024 * 1024).ReadAsync(data);

        var content = new MultipartFormDataContent();
        var arrContent = new ByteArrayContent(data);
        arrContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);

        content.Add(arrContent, file.Name, file.Name);

        var result = await Planet.Node.PostMultipartDataWithResponse<string>($"upload/planetbg/{Planet.Id}", content);
        _bgResult = result;

        if (result.Success)
        {
            Planet.HasCustomBackground = true;
            Planet.Version += 1;
        }

        StateHasChanged();
    }

    private async Task OnSaveChanges()
    {
        if (_nameValue != Planet.Name)
        {
            Planet.Name = _nameValue;
        }

        var result = await Planet.UpdateAsync();
        _mainResult = result;

        if (result.Success && _selectedPrimaryChannel is not null &&
            _selectedPrimaryChannel.Id != (Planet.PrimaryChatChannel?.Id ?? 0))
        {
            var primaryResult = await Planet.Node.PutAsync(
                $"api/planets/{Planet.Id}/channels/primary/{_selectedPrimaryChannel.Id}", "");
            if (!primaryResult.Success)
                _mainResult = primaryResult;
        }

        StateHasChanged();
    }


    private void HandleTagSelection(PlanetTag planetTag)
    {
        if (Planet.Tags == null) Planet.Tags = new List<PlanetTag>();
        if (Planet.Tags.Any(t => t.Id == planetTag.Id)) return;
        Planet.Tags.Add(planetTag);
    }

    private void HandleTagRemoved(PlanetTag planetTag)
    {
        if (Planet.Tags == null) return;
        Planet.Tags.RemoveAll(t => t.Id == planetTag.Id);
    }
}
