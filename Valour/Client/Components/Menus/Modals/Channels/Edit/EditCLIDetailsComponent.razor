<div class="settings-page">
    <div class="editor-section">
        <h3 class="editor-section-title">
            <i class="bi bi-info-circle"></i>
            Channel Details
        </h3>

        <div class="form-group">
            <label>Name</label>
            <input class="v-input" type="text" placeholder="Channel name" @bind-value="@_nameValue"/>
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea class="v-input" rows="3" placeholder="What is this channel about?" @bind="@_descValue" @bind:event="oninput"></textarea>
        </div>

        <ResultLabel Result="@_result" />

        <div class="actions">
            <button class="v-btn primary" @onclick="OnSaveChanges">Save Changes</button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Channel Channel { get; set; }

    private string _nameValue;
    private string _descValue;

    private ITaskResult _result;

    protected override void OnInitialized()
    {
        _nameValue = Channel.Name;
        _descValue = Channel.Description;
    }

    private async Task OnSaveChanges()
    {
        if (_nameValue != Channel.Name || _descValue != Channel.Description)
        {
            // Save old values so we can restore if the update fails.
            // We must not mutate the cached model before the server confirms,
            // otherwise the SignalR update won't detect changes and the
            // sidebar won't refresh.
            var oldName = Channel.Name;
            var oldDesc = Channel.Description;

            Channel.Name = _nameValue;
            Channel.Description = _descValue;

            var result = await Channel.UpdateAsync();
            if (!result.Success)
            {
                // Restore old values on failure
                Channel.Name = oldName;
                Channel.Description = oldDesc;
                _result = new TaskResult(false, $"Failed to save changes: {result.Message}");
            }
            else
            {
                _result = new TaskResult(true, "Changes saved successfully.");

                // We mutated the cached model before UpdateAsync (required because
                // it sends `this`), so the SignalR notification may arrive during
                // the await, find no property diffs, and skip firing Updated events.
                // Explicitly fire the event to ensure the sidebar refreshes.
                Channel.InvokeUpdatedEvent(
                    new ModelUpdatedEvent<Channel>(Channel, ModelChange<Channel>.Empty));
            }
        }

        StateHasChanged();
    }
}
