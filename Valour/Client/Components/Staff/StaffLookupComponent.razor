@inject ValourClient Client
@inject StaffService StaffService
@using Valour.Shared.Models.Staff

<!-- Staff PII lookup: user -> email and email -> user. Requires a reason
     and is audit-logged, because this surfaces private data. -->

<div class="staff-lookup">
    <div class="form-group">
        <label>User id, username, username#tag, or email</label>
        <input class="form-control" placeholder="e.g. spike@valour.gg or SpikeViper#0000"
               @bind="_identifier" @bind:event="oninput" />
    </div>
    <div class="form-group">
        <label>Reason (required, audit-logged)</label>
        <input class="form-control" maxlength="512" placeholder="e.g. Support ticket #123"
               @bind="_reason" @bind:event="oninput" />
    </div>
    <button class="v-btn primary"
            disabled="@(string.IsNullOrWhiteSpace(_identifier) || string.IsNullOrWhiteSpace(_reason))"
            @onclick="Lookup">Look up</button>

    @if (_error is not null)
    {
        <p class="text-danger mt-2">@_error</p>
    }

    @if (_result is not null)
    {
        <div class="lookup-result mt-3">
            <table class="lookup-table">
                <tbody>
                <tr><td>User</td><td>@_result.Name#@_result.Tag (@_result.UserId)</td></tr>
                <tr><td>Email</td><td>@_result.Email @(_result.EmailVerified ? "(verified)" : "(unverified)")</td></tr>
                <tr><td>Created</td><td>@_result.TimeCreated.ToString("u")</td></tr>
                <tr><td>Disabled</td><td>@(_result.Disabled ? "Yes" : "No")</td></tr>
                <tr><td>Bot</td><td>@(_result.Bot ? $"Yes (owner: {_result.OwnerId})" : "No")</td></tr>
                <tr>
                    <td>Prior name</td>
                    <td>
                        @if (string.IsNullOrWhiteSpace(_result.PriorName))
                        {
                            <span>None</span>
                        }
                        else
                        {
                            <span>@_result.PriorName @(_result.HidePriorName ? "(hidden from users)" : "(visible)")</span>
                        }
                    </td>
                </tr>
                <tr><td>2FA</td><td>@(_result.HasMfa ? "Enabled" : "Not set up")</td></tr>
                @if (_result.PendingMfaRemovalAt is not null)
                {
                    <tr><td>2FA removal</td><td class="text-danger">Pending — executes @_result.PendingMfaRemovalAt?.ToString("u")</td></tr>
                }
                </tbody>
            </table>
            <button class="v-btn secondary mt-2" @onclick="OpenTools">Open staff tools</button>
        </div>
    }
</div>

@code {
    [CascadingParameter]
    public ModalRoot ModalRoot { get; set; }

    private string _identifier = string.Empty;
    private string _reason = string.Empty;
    private string _error;
    private StaffUserLookupResult _result;

    private async Task Lookup()
    {
        _error = null;
        _result = null;

        var result = await StaffService.LookupUserAsync(_identifier.Trim(), _reason.Trim());
        if (!result.Success)
        {
            _error = result.Message;
        }
        else
        {
            _result = result.Data;
        }

        StateHasChanged();
    }

    private async Task OpenTools()
    {
        var user = await Client.UserService.FetchUserAsync(_result.UserId);
        if (user is null)
            return;

        ModalRoot.OpenModal<StaffUserToolsModal>(new StaffUserToolsModal.ModalParams()
        {
            User = user
        });
    }
}
