@using Valour.Sdk.ModelLogic.QueryEngines
@inject ValourClient Client
@inject StaffService StaffService

<QueryTable 
    @ref="@_table"
    Columns="@_columns"
    Engine="@_engine"
    ShowSearch="@true"
    SearchPlaceholder="Search name..."
    Infinite="@true"
/>

@code {
    [CascadingParameter]
    public ModalRoot ModalRoot { get; set; }

    private QueryTable<User> _table;

    private List<ColumnDefinition<User>> _columns;
    
    private string _nameSearch = string.Empty;

    private StaffUserQueryEngine _engine;

    protected override void OnInitialized()
    {
        _engine = new StaffUserQueryEngine(Client.PrimaryNode);
        
        _columns = new()
        {
            new ()
            {
                Name = "Card",
                RenderFragment = (rowData) =>
                    @<UserInfoComponent User="@rowData.Row" ShowBadges="false" ShowState="false" />
            },
            new ()
            {
                Name = "Name",
                RenderFragment = (rowData) =>
                    @<span>@rowData.Row.NameAndTag</span>
            },
            new ()
            {
                Name = "Actions",
                RenderFragment = (rowData) =>
                    @<div class="button-row">
                        <button class="v-btn" @onclick="@(() => OpenTools(rowData.Row))">Tools</button>

                        @if (rowData.Row.Disabled)
                        {
                            <button class="v-btn primary" @onclick="@(() => EnableUser(rowData.Row))">Enable</button>
                        }
                        else
                        {
                            <button class="v-btn secondary" @onclick="@(() => DisableUser(rowData.Row))">Disable</button>
                        }

                        <button class="v-btn danger" @onclick="@(() => DeleteUser(rowData.Row))">Delete</button>
                    </div>
            }
        };
    }

    /* Staff Controls */

    private void OpenTools(User user)
    {
        ModalRoot.OpenModal<StaffUserToolsModal>(new StaffUserToolsModal.ModalParams()
        {
            User = user
        });
    }

    public void DisableUser(User user)
    {
        ModalRoot.OpenModal<StaffReasonModalComponent>(new StaffReasonModalComponent.ModalParams()
        {
            Title = $"Disable {user.NameAndTag}?",
            Description = "The account is disabled and every session is signed out.",
            ConfirmText = "Disable",
            Danger = true,
            ConfirmEvent = async reason =>
            {
                var toastData = new ProgressToastData<TaskResult>()
                {
                    Title = "Disabling User",
                    SuccessMessage = "User has been disabled",
                    Message = "Waiting for result...",
                    ProgressTask = StaffService.SetUserDisabledAsync(user.Id, true, reason)
                };

                var result = await ToastContainer.Instance.WaitToastWithTaskResult(toastData);

                if (result.Success)
                {
                    await _table.Requery();
                }
            }
        });
    }

    private void EnableUser(User user)
    {
        ModalRoot.OpenModal<StaffReasonModalComponent>(new StaffReasonModalComponent.ModalParams()
        {
            Title = $"Enable {user.NameAndTag}?",
            Description = "The account is re-enabled and can log in again.",
            ConfirmText = "Enable",
            ConfirmEvent = async reason =>
            {
                var toastData = new ProgressToastData<TaskResult>()
                {
                    Title = "Enabling User",
                    SuccessMessage = "User has been enabled",
                    Message = "Waiting for result...",
                    ProgressTask = StaffService.SetUserDisabledAsync(user.Id, false, reason)
                };

                var result = await ToastContainer.Instance.WaitToastWithTaskResult(toastData);

                if (result.Success)
                {
                    await _table.Requery();
                }
            }
        });
    }

    public void DeleteUser(User user)
    {
        ModalRoot.OpenModal<StaffReasonModalComponent>(new StaffReasonModalComponent.ModalParams()
        {
            Title = $"Hard Delete {user.NameAndTag}?",
            Description = "This CANNOT be undone. The account and its data are permanently deleted.",
            CancelText = "Cancel",
            ConfirmText = "DELETE",
            Danger = true,
            ConfirmEvent = async reason =>
            {
                var toastData = new ProgressToastData<TaskResult>()
                {
                    Title = "Deleting User",
                    SuccessMessage = "User has been deleted",
                    Message = "Waiting for result...",
                    ProgressTask = StaffService.DeleteUserAsync(user.Id, reason)
                };

                var result = await ToastContainer.Instance.WaitToastWithTaskResult(toastData);

                if (result.Success)
                {
                    await _table.Requery();
                }
            }
        });
    }
}