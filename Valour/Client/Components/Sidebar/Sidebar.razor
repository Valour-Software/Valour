@inject IJSRuntime JsRuntime
@inject IAppStorage LocalStorage
@inject PlanetService PlanetService
@implements IAsyncDisposable

<div class="sidebar-container @ActiveClass @FlipClass">
	<div id="@_id" class="sidebar-menu">
		<SidebarOpenTab OnClicked="OnOpenTabClicked" Open="@_active" Flip="Flip"></SidebarOpenTab>
		<div class="sidebar">
			<VersionComponent />
			<div class="sidebar-content">
				<SlideSwap Index="@SelectedTab" Content="@VisibleTabItems[SelectedTab].RenderContent" />
			</div>
			<div class="sidebar-tabstrip">
				@if (!Flip)
				{
					<SelfInfoComponent />
				}
				<SidebarTabstrip TabItems="@VisibleTabItems" Sidebar="@this" Flip="Flip" />
			</div>
		</div>
	</div>
</div>

@code {

	private readonly List<TabStripItem> _tabItems = new()
	{
		new TabStripItem<PlanetsDmDirectory>("Planets", "globe-americas", 16),
		new TabStripItem<FriendListComponent>("Friends", "person-fill", 21),
		new TabStripItem<ChannelDirectory>("Channels", "chat-left-fill", 15),
		new TabStripItem<NotificationsListComponent>("Notifications", "bell-fill", 16)
	};

	private const string ChannelsTabName = "Channels";
	private const string PlanetsTabName = "Planets";

	// The channel list only shows connected planets, so hide its tab entirely
	// when none are open.
	private bool ChannelsTabAvailable => PlanetService.ConnectedPlanets.Count > 0;

	public List<TabStripItem> VisibleTabItems =>
		_tabItems.Where(x => x.Name != ChannelsTabName || ChannelsTabAvailable).ToList();
	
	private static event Func<Task> OnToggleMobileSidebar;
	public static async Task ToggleMobileSidebar()
	{
		// Only toggle sidebar on mobile devices
		if (DeviceInfo.IsMobile && OnToggleMobileSidebar is not null)
			await OnToggleMobileSidebar.Invoke();
	}
	
	[Parameter]
	public bool Flip { get; set; }
	public string FlipClass => Flip ? "flip" : "";
	
	private string _selectedTabName = PlanetsTabName;

	// Index of the active tab within the currently visible tabs.
	public int SelectedTab
	{
		get
		{
			var index = VisibleTabItems.FindIndex(x => x.Name == _selectedTabName);
			return index < 0 ? 0 : index;
		}
	}

	private bool _active = !DeviceInfo.IsMobile;
	
	private string ActiveClass => _active ? "sidebar-active" : "";

	private string _id = "sidebar-" + Guid.NewGuid();
	
	/// <summary>
	/// Dotnet object reference for use in Javascript
	/// </summary>
	private DotNetObjectReference<Sidebar> _thisRef;
	private bool _disposed;

	/// <summary>
	/// Module for calling Javascript functions
	/// </summary>
	private IJSObjectReference _jsModule;

	private IJSObjectReference _jsRef;
	
	
	protected override async Task OnInitializedAsync()
	{
		_mainSidebar = this;

		if (await LocalStorage.ContainsKeyAsync("sidebar"))
		{
			var name = await LocalStorage.GetStringAsync("sidebar");
			_selectedTabName = _tabItems.Any(x => x.Name == name) ? name : PlanetsTabName;
		}
		else
		{
			_selectedTabName = PlanetsTabName;
		}

		EnsureValidSelection();

		OnToggleMobileSidebar += OnOpenTabClicked;
		WindowService.FocusedTabChanged += OnFocusedTabChanged;
		PlanetService.ConnectedPlanetsUpdated += OnConnectedPlanetsUpdated;
	}

	private void OnFocusedTabChanged(WindowTab tab)
	{
		InvokeAsync(() =>
		{
			if (tab?.Content?.PlanetId is not null && _selectedTabName != ChannelsTabName)
			{
				_selectedTabName = ChannelsTabName;
				StateHasChanged();
			}
		});
	}

	private void OnConnectedPlanetsUpdated()
	{
		InvokeAsync(() =>
		{
			EnsureValidSelection();
			StateHasChanged();
		});
	}

	// Keeps selection off the Channels tab when it is hidden.
	private void EnsureValidSelection()
	{
		if (_selectedTabName == ChannelsTabName && !ChannelsTabAvailable)
			_selectedTabName = PlanetsTabName;
	}

	public async Task OnSelected(int index, TabStripItem tab)
	{
		await LocalStorage.SetStringAsync("sidebar", tab.Name);
		_selectedTabName = tab.Name;
		StateHasChanged();
	}
	
	async ValueTask IAsyncDisposable.DisposeAsync()
	{
		_disposed = true;

		try
		{
			if (_jsModule is not null)
			{
				await _jsModule.InvokeVoidAsync("cleanup");
				await _jsModule.DisposeAsync();
			}
		}
		catch (JSDisconnectedException) { }
		catch (JSException) { }

		_thisRef?.Dispose();
		OnToggleMobileSidebar -= OnOpenTabClicked;
		WindowService.FocusedTabChanged -= OnFocusedTabChanged;
		PlanetService.ConnectedPlanetsUpdated -= OnConnectedPlanetsUpdated;
	}
	
	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			_thisRef = DotNetObjectReference.Create(this);
			_jsModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./_content/Valour.Client/Components/Sidebar/Sidebar.razor.js");

			if (_disposed)
				return;

			_jsRef = await _jsModule.InvokeAsync<IJSObjectReference>("init", _thisRef, _id);
		}
	}

	public static Sidebar _mainSidebar;
	
	public static async Task ToggleSidebar()
	{
		if (_mainSidebar is null)
			return;

		await _mainSidebar.InvokeAsync(_mainSidebar.OnOpenTabClicked);
	}

	/// <summary>
	/// Closes the mobile sidebar overlay if it is open, e.g. for the Android
	/// hardware back button. Returns true if the sidebar was open and closed.
	/// </summary>
	public static async Task<bool> TryCloseMobileSidebarExternalAsync()
	{
		var sidebar = _mainSidebar;
		if (sidebar is null || !DeviceInfo.IsMobile)
			return false;

		var closed = false;

		await sidebar.InvokeAsync(async () =>
		{
			if (sidebar._jsRef is null)
				return;

			try
			{
				if (!await sidebar._jsRef.InvokeAsync<bool>("isOpen"))
					return;

				await sidebar._jsRef.InvokeVoidAsync("setOpen", false);
				closed = true;
			}
			catch (JSException) { }
			catch (JSDisconnectedException) { }
		});

		return closed;
	}

	private async Task OnOpenTabClicked()
	{
		if (!DeviceInfo.IsMobile)
		{
			_active = !_active;
			if (_jsRef is not null)
				await _jsRef.InvokeVoidAsync("clearInlineTransform");
			StateHasChanged();
		}
		else
		{
			await _jsRef.InvokeVoidAsync("toggleOpen");	
		}
	}
}
