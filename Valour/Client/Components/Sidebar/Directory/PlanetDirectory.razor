@using Valour.Shared.Utilities
@implements IDisposable
@implements IAsyncDisposable
@inject ChannelDragManager DragManager
@inject ContextMenuService ContextMenuService
@inject ChannelService ChannelService
@inject UnreadService UnreadService
@inject NotificationService NotificationService
@inject IJSRuntime JsRuntime

<div 
    class="@GetCssClass()" 
    id="list-@Planet.Id"
    @oncontextpress="@OnContextPress">
    <div class="header-wrapper" style="cursor:pointer" id="list-inner-@Planet.Id">
        <div @onclick='@OnClick' class="header" ondragover="event.preventDefault();">
            <div class="left">
                <PlanetIcon Planet="@Planet" Size="24" Unread="@_hasUnread"/>
                <p class="planet-name">
                    @Planet.Name
                </p>
                @if (Planet.Node?.IsExternal == true)
                {
                    <i class="bi bi-diagram-3-fill community-host-icon"
                       title="@($"Hosted by {Planet.Node.Name}, not by Valour")"></i>
                }
                @if (Planet.SelfHostedMedia)
                {
                    <i class="bi bi-hdd-network-fill custom-media-icon"
                       title="This planet stores media on its owner's own infrastructure, not on Valour"></i>
                }
            </div>
            <div class="right">
                @if (_notifications > 0)
                {
                    <div class="notif-badge">
                        <span>@_notifications</span>
                    </div>
                }
                
                @if (_canEdit)
                {
                    <div class="edit-button" @onclick:stopPropagation="true" @onclick="@OnClickEdit">
                        <i class="bi bi bi-gear-fill"></i>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="channel-list @(Open ? "open" : "")">
        <div class="channel-list-inner">
            <div class="v-gradient-underline"></div>
            <div class="list-wrapper">
                <div class="channel planet-about" @onclick="OnClickPlanetInfo">
                    <i class="bi bi-info-circle-fill planet-pseudo-icon"></i>
                    <p class="name">
                        About Planet
                    </p>
                </div>
                <div class="channel planet-rules" @onclick="OnClickPlanetRules">
                    <i class="bi bi-list-check planet-pseudo-icon"></i>
                    <p class="name">
                        Rules
                    </p>
                </div>
                @if (Planet.EnableWiki)
                {
                    <WikiDirectorySection Planet="@Planet"/>
                }
                @if (Planet.EnableThreads)
                {
                    <ThreadsDirectorySection Planet="@Planet"/>
                }

                @foreach (var root in RootChannels)
                {
                    <ChannelDirectoryItem @key="@root.Id"
                                     PlanetComponent="@this"
                                     Channel="@root"/>
                }
            </div>
        </div>
    </div>
</div>
 
@code {
    public HybridEvent ChannelsNeedRefresh;
    
    /// <summary>
    /// A hashset of all the categories which have been closed (minimized)
    /// </summary>
    public HashSet<long> ClosedCategories = new();
    
    public List<Channel> RootChannels = new();
    
    [Parameter] 
    public Planet Planet { get; set; }

    public bool Open { get; set; } = true;

    private int _notifications;
    private bool _hasUnread;
    
    private bool _canEdit;
    private DotNetObjectReference<PlanetDirectory> _pointerDragRef;
    private IJSObjectReference _pointerDragModule;
    private IJSObjectReference _pointerDragRegistration;

    protected override async Task OnInitializedAsync()
    {
        Planet.Channels.Changed += OnChannelsChanged;
        UnreadService.PlanetUnreadChanged += OnPlanetUnreadChanged;

        await UnreadService.FetchUnreadPlanetChannelsAsync(Planet.Id);
        
        DetermineUnreadAndNotifications();
        DeterminePermissions();
        DetermineRootChannels();
        
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _pointerDragRef = DotNetObjectReference.Create(this);
        _pointerDragModule = await JsRuntime.InvokeAsync<IJSObjectReference>(
            "import",
            "./_content/Valour.Client/Components/Sidebar/Directory/PlanetDirectory.razor.js");
        _pointerDragRegistration = await _pointerDragModule.InvokeAsync<IJSObjectReference>(
            "initializeChannelPointerDrag",
            $"list-{Planet.Id}",
            _pointerDragRef,
            Valour.Client.Device.DeviceInfo.IsEmbedded);
    }

    [JSInvokable]
    public async Task DropChannelFromPointer(string sourceId, string destinationId, string zone)
    {
        if (!long.TryParse(sourceId, out var sourceChannelId) ||
            !long.TryParse(destinationId, out var destinationChannelId))
            return;

        var source = Planet.Channels.Get(sourceChannelId);
        var destination = Planet.Channels.Get(destinationChannelId);
        if (source is null || destination is null)
            return;

        var insideCategory = string.Equals(zone, "inside", StringComparison.Ordinal);
        var placeBefore = string.Equals(zone, "before", StringComparison.Ordinal);
        await DragManager.MoveChannelAsync(source, destination, placeBefore, insideCategory);
    }

    private void OnPlanetUnreadChanged(long planetId)
    {
        if (planetId != Planet.Id)
            return;

        InvokeAsync(() =>
        {
            DetermineUnreadAndNotifications();
            StateHasChanged();
        });
    }
    
    private void DetermineRootChannels()
    {
        RootChannels = Planet.Channels
            .Where(ShouldShowChannel)
            .Where(x => x.ParentId is null || !Planet.Channels.ContainsId(x.ParentId.Value))
            .ToList();
    }

    private void OnChannelsChanged(IModelEvent<Channel> eventData)
    {
        InvokeAsync(() =>
        {
            Console.WriteLine("Channels changed");
            DetermineRootChannels();
            StateHasChanged();
        });
    }
    
    public bool GetVisible(Channel channel)
    {
        if (!ShouldShowChannel(channel))
            return false;

        if (channel.ParentId is not null)
        {
            if (ClosedCategories.Contains(channel.ParentId.Value))
            {
                return false;
            }
            
            var parent = Planet.Channels.Get(channel.ParentId.Value);
            if (parent is null)
                return true;
            
            return GetVisible(parent);
        }
        else
        {
            return true;
        }
    }

    public bool ShouldShowChannel(Channel channel)
    {
        if (channel.ChannelType != ChannelTypeEnum.PlanetChat)
            return true;

        return !Planet.Channels.Any(x =>
            ISharedChannel.IsPlanetCallType(x.ChannelType) &&
            x.AssociatedChatChannelId == channel.Id);
    }

    public void SetCategoryOpened(long categoryId, bool value)
    {
        if (value)
            ClosedCategories.Add(categoryId);
        else
            ClosedCategories.Remove(categoryId);
        
        StateHasChanged();
    }

    private void DeterminePermissions()
    {
        _canEdit = Planet.MyMember?.HasPermission(PlanetPermissions.Manage) ?? false;
    }

    private void DetermineUnreadAndNotifications()
    {
        _hasUnread = UnreadService.IsPlanetUnread(Planet.Id);
        _notifications = NotificationService.GetPlanetNotifications(Planet.Id);
    }

    private void OnContextPress(ContextPressEventArgs e)
    {
        ContextMenuService.Root.OpenMenu<PlanetContextMenu>(e,
            new PlanetContextMenu.PlanetContextParams()
            {
                Planet = Planet
            }
        );
    }
    
    public string GetCssClass() => 
        Open ? "planet is-open" : "planet";

    public string GetArrowStyle() =>
        Open ? "transform: rotate(90deg);" : "";

    public void OnClick()
    {
        Open = !Open;
        StateHasChanged();
    }
    
    private void OnClickEdit()
    {
        var data = new EditPlanetComponent.ModalParams()
        {
            Planet = Planet
        };
        
        ModalRoot.Instance.OpenModal<EditPlanetComponent>(data);
    }
    
    private async Task OnClickPlanetInfo()
    {
        var newWindowContent = PlanetInfoWindowComponent.GetDefaultContent(Planet);
        await WindowService.OpenWindowAtFocused(newWindowContent);
    }

    private async Task OnClickPlanetRules()
    {
        var newWindowContent = PlanetRulesWindowComponent.GetDefaultContent(Planet);
        await WindowService.OpenWindowAtFocused(newWindowContent);
    }

    void IDisposable.Dispose()
    {
        Planet.Channels.Changed -= OnChannelsChanged;
        UnreadService.PlanetUnreadChanged -= OnPlanetUnreadChanged;
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        ((IDisposable)this).Dispose();

        if (_pointerDragRegistration is not null)
        {
            try
            {
                await _pointerDragRegistration.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        if (_pointerDragModule is not null)
        {
            try
            {
                await _pointerDragModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        _pointerDragRef?.Dispose();
    }
}
