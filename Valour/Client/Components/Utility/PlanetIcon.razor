@* Standard circular planet icon with optional unread gradient ring *@

@if (Planet is null)
{
    return;
}

<div class="planet-icon @(Unread ? "unread" : "")" style="--planet-icon-size: @(Size)px">
    @if (_iconText is not null)
    {
        <div class="planet-icon-img text-icon">
            <span style="font-size: @(_fontSize.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))px">@_iconText</span>
        </div>
    }
    else
    {
        <LazyImage CssClass="planet-icon-img"
                   Alt="@($"{Planet.Name}'s icon")"
                   Src="@_iconUrl"
                   FallbackSrc="_content/Valour.Client/media/logo-circle.svg">
            <Placeholder>
                <div class="planet-icon-img text-icon">
                    <span style="font-size: @(_fontSize.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))px">@_placeholderText</span>
                </div>
            </Placeholder>
        </LazyImage>
    }
</div>

@code {
    [Parameter]
    public Planet Planet { get; set; }

    [Parameter]
    public int Size { get; set; } = 36;

    /// <summary>
    /// Shows the unread state as a gradient ring around the icon
    /// </summary>
    [Parameter]
    public bool Unread { get; set; }

    [Parameter]
    public IconFormat Format { get; set; } = IconFormat.WebpAnimated64;

    private string _iconUrl;
    private string _iconText;
    private string _placeholderText;
    private float _fontSize;

    protected override void OnParametersSet()
    {
        if (Planet is null)
            return;

        _placeholderText = ISharedPlanet.GetCommunityShortCode(Planet);
        _fontSize = (float)Size / (_placeholderText.Length + 1);

        if (Planet.HasCustomIcon)
        {
            _iconUrl = Planet.GetIconUrl(Format);
            _iconText = null;
        }
        else
        {
            _iconUrl = "_content/Valour.Client/media/logo-circle.svg";
            _iconText = _placeholderText;
        }
    }
}
