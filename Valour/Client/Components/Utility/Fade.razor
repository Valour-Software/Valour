@inject IJSRuntime JsRuntime

<div @ref="@_containerRef" class="fade-container">
    @ChildContent
</div>

@code {
    [Parameter]
    public RenderFragment ChildContent { get; set; }
    
    /// <summary>
    /// Module for calling Javascript functions
    /// </summary>
    private IJSObjectReference _jsModule;

    private ElementReference _containerRef;
    
    [Parameter]
    public Func<Task> OnFadeOut { get; set; }

    protected override Task OnInitializedAsync()
    {
        return Task.CompletedTask;
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./_content/Valour.Client/Components/Utility/Fade.razor.js?version=$(SHORTHASH)");
            await _jsModule.InvokeVoidAsync("fadeIn", _containerRef);
        }
    }
    
    public async Task FadeOut()
    {
        // The visual fade is best-effort: OnFadeOut must always run, otherwise
        // callers waiting on it (e.g. modal removal) would be stuck forever.
        try
        {
            if (_jsModule is not null)
            {
                await _jsModule.InvokeVoidAsync("fadeOut", _containerRef);
                await Task.Delay(200);
            }
        }
        catch
        {
            // JS interop failed - skip the animation and finish immediately
        }

        if (OnFadeOut is not null)
        {
            await OnFadeOut.Invoke();
        }
    }

}