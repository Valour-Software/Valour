<div class="tri-toggle" role="group" aria-label="Permission state">
    <button type="button"
            class="seg deny @(State == TriButtonState.No ? "active" : "")"
            title="Deny"
            @onclick="@(async () => await OnChangeState(TriButtonState.No))">
        <i class="bi bi-x-lg"></i>
    </button>
    <button type="button"
            class="seg inherit @(State == TriButtonState.Disabled ? "active" : "")"
            title="Inherit"
            @onclick="@(async () => await OnChangeState(TriButtonState.Disabled))">
        <i class="bi bi-dash-lg"></i>
    </button>
    <button type="button"
            class="seg allow @(State == TriButtonState.Yes ? "active" : "")"
            title="Allow"
            @onclick="@(async () => await OnChangeState(TriButtonState.Yes))">
        <i class="bi bi-check-lg"></i>
    </button>
</div>

@code {
    public enum TriButtonState
    {
        Disabled, Yes, No
    }

    public TriButtonState State { get; set; }

    [Parameter]
    public Func<TriButtonState, Task> OnStateChange { get; set; }

    public void Refresh()
    {
        StateHasChanged();
    }

    public async Task OnChangeState(TriButtonState newState, bool events = true)
    {
        State = newState;
        StateHasChanged();

        if (events && OnStateChange is not null)
            await OnStateChange.Invoke(newState);
    }
}
