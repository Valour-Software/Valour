@inject NavigationManager NavManager
@inject ValourClient Client
@inject PlanetService PlanetService
@using Valour.Sdk.Nodes

@* Shared landing UI + join flow for the invite (/I/{code}) and discoverable
   (/D/{id}) pages. The pages differ only in how they load the planet info and
   how the join is performed; everything below is common. *@

<NebulaBackground ContentClasses="absolute-center">
    <div class="invite-card">
        <div class="col-md-12">
            <section class="text-center">

                @if (Result is null)
                {
                    <h2>Loading...</h2>
                }
                else if (!Result.Value.Success)
                {
                    <p class="invite-prompt text-danger">@(Result.Value.Message ?? "An error occurred.")</p>
                    <button class="v-btn center mt-4" @onclick="OnClose">Back to Home</button>
                }
                else
                {
                    if (!Client.IsLoggedIn)
                    {
                        <div class="invite-planet-preview">
                            <DiscoveryPlanetCard PlanetInfo="@Result.Value.Data" HideActions="true"/>
                        </div>
                        <p class="invite-prompt">Create an account or log in to join this planet</p>
                        <div class="invite-actions">
                            <button class="v-btn mt-2 join-btn" @onclick="OnClickRegister">Join Valour</button>
                            <button class="v-btn mt-2 login-btn" @onclick="OnClickLogin">Log In</button>
                        </div>
                    }
                    else if (_alreadyJoined)
                    {
                        <DiscoveryPlanetCard PlanetInfo="@Result.Value.Data" HideActions="true"/>
                        <p class="already-joined-text">You're already a member of this planet!</p>
                        <button class="v-btn mt-2" @onclick="OnClose">Go to Home</button>
                    }
                    else if (!string.IsNullOrWhiteSpace(Result.Value.Data.NodeDomain))
                    {
                        @* Community-hosted planet: first-contact warning before joining. *@
                        <DiscoveryPlanetCard PlanetInfo="@Result.Value.Data" HideActions="true"/>
                        <div class="custom-media-warning mt-2">
                            <i class="bi bi-hdd-network-fill"></i>
                            <span>
                                This planet is hosted by <b>@Result.Value.Data.NodeDomain</b> — a community server,
                                not Valour. Messages and media you post there are stored on their servers and visible
                                to their operator. Valour's moderation and data-deletion guarantees don't fully apply,
                                and your IP address is visible to this server.
                            </span>
                        </div>
                        @if (_joining)
                        {
                            <p class="invite-prompt">Joining...</p>
                        }
                        else
                        {
                            <button class="v-btn mt-3 join-btn" @onclick="@(() => OnJoinFederated(Result.Value.Data))">
                                I understand — join @Result.Value.Data.NodeDomain
                            </button>
                        }
                        @if (_joinError is not null)
                        {
                            <p class="invite-prompt text-danger">@_joinError</p>
                        }
                    }
                    else
                    {
                        <DiscoveryPlanetCard PlanetInfo="@Result.Value.Data" OnJoin="OnJoinPlanet"/>
                        @if (Result.Value.Data.SelfHostedMedia)
                        {
                            <div class="custom-media-warning mt-2">
                                <i class="bi bi-hdd-network-fill"></i>
                                <span>
                                    This planet stores its media on infrastructure controlled by the planet's owner,
                                    not by Valour. Files shared here are not scanned by Valour, and the planet's
                                    media host can see your IP address when you view or upload media.
                                </span>
                            </div>
                        }
                        @if (_joining)
                        {
                            <p class="invite-prompt">Joining planet...</p>
                        }
                        else if (_joinError is not null)
                        {
                            <p class="invite-prompt text-danger">@_joinError</p>
                        }
                    }
                }
            </section>
        </div>
    </div>
</NebulaBackground>

@code {
    /// <summary>
    /// The loaded planet info to display, or null while still loading.
    /// </summary>
    [Parameter]
    public TaskResult<PlanetListInfo>? Result { get; set; }

    /// <summary>
    /// Performs the actual join for the given planet id. Invite and discover
    /// pages join through different endpoints, so the caller supplies this.
    /// </summary>
    [Parameter]
    public Func<long, Task<TaskResult<PlanetMember>>> JoinAsync { get; set; }

    /// <summary>
    /// Relative path to return to after logging in (e.g. "/I/{code}" or "/D/{id}").
    /// </summary>
    [Parameter]
    public string LoginReturnPath { get; set; }

    /// <summary>
    /// URL the "Join Valour" (register) button navigates to.
    /// </summary>
    [Parameter]
    public string RegisterUrl { get; set; }

    private bool _alreadyJoined;
    private string _joinError;
    private bool _joining;

    protected override void OnParametersSet()
    {
        if (Result.HasValue &&
            Result.Value.Data is not null &&
            IsAlreadyJoined(Result.Value.Data.PlanetId))
        {
            _alreadyJoined = true;
        }
    }

    private bool IsAlreadyJoined(long planetId)
    {
        var planets = PlanetService.JoinedPlanets;
        for (var i = 0; i < planets.Count; i++)
        {
            if (planets[i].Id == planetId)
                return true;
        }
        return false;
    }

    private void OnClickLogin() =>
        NavManager.NavigateTo($"/?redirect={LoginReturnPath}", true);

    private void OnClickRegister() =>
        NavManager.NavigateTo(RegisterUrl, true);

    public async Task OnClose()
    {
        await PlanetService.FetchJoinedPlanetsAsync();
        NavManager.NavigateTo("/");
    }

    private async Task OnJoinPlanet(PlanetListInfo planetInfo)
    {
        if (_joining)
            return;

        _joinError = null;
        _joining = true;
        StateHasChanged();

        TaskResult<PlanetMember> result;
        try
        {
            result = await JoinAsync(planetInfo.PlanetId);
        }
        finally
        {
            _joining = false;
        }

        if (result.Success)
        {
            _alreadyJoined = true;
            await GoToPlanetAsync(planetInfo.PlanetId);
            return;
        }

        // The join can fail simply because we're already a member (e.g. a stale
        // joined-planets list). Re-check before surfacing an error.
        await PlanetService.FetchJoinedPlanetsAsync();
        if (IsAlreadyJoined(planetInfo.PlanetId))
        {
            _alreadyJoined = true;
            await GoToPlanetAsync(planetInfo.PlanetId);
            return;
        }

        _joinError = result.Message ?? "Failed to join planet.";
    }

    /// <summary>
    /// Join flow for a community-hosted planet: accept the node's domain
    /// (first-contact warning was shown above), record the membership at the
    /// hub, then hand off to the node connection.
    /// </summary>
    private async Task OnJoinFederated(PlanetListInfo info)
    {
        if (_joining)
            return;

        _joinError = null;
        _joining = true;
        StateHasChanged();

        try
        {
            var accept = await PlanetService.AcceptFederationDomainAsync(info.NodeDomain);
            if (!accept.Success)
            {
                _joinError = accept.Message ?? "Could not accept the domain.";
                return;
            }

            var join = await PlanetService.JoinFederatedPlanetAsync(info.PlanetId);
            if (!join.Success)
            {
                _joinError = join.Message ?? "Could not join the community planet.";
                return;
            }

            // Membership is recorded at the hub. Connecting to the community
            // node (opening its realtime session and rendering the planet) is
            // handled by the multi-origin node layer.
            _alreadyJoined = true;
            await ConnectToFederatedPlanetAsync(info.PlanetId, info.NodeDomain);
        }
        finally
        {
            _joining = false;
        }
    }

    private async Task ConnectToFederatedPlanetAsync(long planetId, string nodeDomain)
    {
        // Bring up a connection to the community node (HTTP + realtime on its
        // own origin, authenticated by a federation-exchanged token).
        var node = await Client.NodeService.ConnectToFederatedNodeAsync(nodeDomain);
        if (node is null)
        {
            _joinError = $"Joined, but couldn't reach {nodeDomain}. It may be offline.";
            return;
        }

        // Route this planet's requests (and realtime) to the community node instead
        // of the primary node, so normal planet loading talks to the right origin.
        Client.NodeService.SetKnownByPlanet(planetId, node.Name);

        await PlanetService.FetchJoinedPlanetsAsync();
        NavManager.NavigateTo("/", true);
    }

    private async Task GoToPlanetAsync(long planetId)
    {
        var planet = await PlanetService.FetchPlanetAsync(planetId);
        if (planet is not null)
        {
            await planet.FetchInitialDataAsync();
            var channel = planet.PrimaryChatChannel;
            if (channel is not null)
            {
                NavManager.NavigateTo($"/planetchannels/{planetId}/{channel.Id}/0", true);
                return;
            }
        }

        await PlanetService.FetchJoinedPlanetsAsync();
        NavManager.NavigateTo("/", true);
    }
}
