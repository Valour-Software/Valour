@using Valour.Sdk.Models

<CustomDropdown TItem="PlanetRole"
                Items="@Roles"
                InitialItem="@SelectedRole"
                Placeholder="Select Role"
                SearchFunc="@RoleSearch"
                SelectedItemChanged="@OnRoleSelected">
    <ItemTemplate Context="role">
        <RolePill Role="@role"/>
    </ItemTemplate>
</CustomDropdown>

@code {
    [Parameter]
    public IEnumerable<PlanetRole> Roles { get; set; } = Array.Empty<PlanetRole>();

    [Parameter]
    public long Value { get; set; }

    [Parameter]
    public EventCallback<long> ValueChanged { get; set; }

    private PlanetRole SelectedRole => Roles.FirstOrDefault(r => r.Id == Value);

    private static bool RoleSearch(PlanetRole role, string search) =>
        role.Name?.Contains(search, StringComparison.OrdinalIgnoreCase) == true;

    private async Task OnRoleSelected(PlanetRole role)
    {
        if (role is null)
            return;

        Value = role.Id;
        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(role.Id);
    }
}
