@using Version = Valour.Shared.Version

<div class="version">
    @if (DeviceInfo.IsMobile)
    {
        <i class="bi bi-list open-menu" @onclick="Sidebar.ToggleMobileSidebar"></i>
    }
    <p class="text" style="cursor: pointer" @onclick="OnClickLogo">Valour Alpha V@(GetVersionNumber()) <span style="font-size: var(--font-size-2xs); color: #7A7A7A">(@GetShortHash())</span></p>
</div>

@code {

    private string GetVersionNumber()
    {
        var baseVer = typeof(ISharedUser)?.Assembly?.GetName()?.Version?.ToString() ?? "?.?.?.?";
        return baseVer.Substring(0, baseVer.Length - 2);
    }

    private string GetShortHash()
    {
        // The build replaces the contiguous placeholder in Version.ShortHash. Keep this
        // comparison split so the replacement step does not turn it into "hash == hash".
        var unreplacedPlaceholder = "$" + "(SHORTHASH)";
        return string.Equals(Version.ShortHash, unreplacedPlaceholder, StringComparison.Ordinal)
            ? "Dev"
            : Version.ShortHash;
    }
    
    private void OnClickLogo()
    {
        WindowService.ResetAll();
    }
}
