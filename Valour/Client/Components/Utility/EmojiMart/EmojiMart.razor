@inject IJSRuntime JsRuntime
@implements IAsyncDisposable

@* Hidden via .picker-hidden (offscreen + visibility) rather than display:none
   so the browser keeps the picker's layout warm — re-laying out the whole
   emoji grid on open causes a visible hitch. *@
<div id="@_id" class="@CssClass @(_hiding ? "picker-closing" : "") @(_shown || _hiding ? "" : "picker-hidden")">
</div>

@code {

    private string _id = "emoji-mart-wrapper" + Guid.NewGuid().ToString();

    [Parameter]
    public string CssClass { get; set; }

    [Parameter]
    public bool StartShown { get; set; } = false;

    /// <summary>
    /// When true (and on mobile), hiding keeps the picker rendered with a
    /// 'picker-closing' class until the close animation finishes.
    /// </summary>
    [Parameter]
    public bool AnimateClose { get; set; } = false;

    [Parameter]
    public string EmojiSet { get; set; } = "native";

    [Parameter]
    public Func<EmojiClickEvent, Task> OnEmojiClick { get; set; }

    [Parameter]
    public Func<OutsidePickerClickEvent, Task> OnClickOutside { get; set; }

    private IJSObjectReference _module;
    private Task _initializationTask;
    private DotNetObjectReference<EmojiMart> _dotNetReference;
    private List<EmojiClickEvent> _customEmojis = new();
    private string _customCategoryIcon = string.Empty;
    private string _customCategoryName = "Planet";

    private bool _shown;
    private bool _hiding;
    private CancellationTokenSource _hideCts;

    protected override void OnInitialized()
    {
        _shown = StartShown;
        StateHasChanged();
    }

    public void ToggleVisible()
    {
        if (_shown)
            Hide();
        else
            Show();
    }

    private void Show()
    {
        _hideCts?.Cancel();
        _hiding = false;
        _shown = true;
        StateHasChanged();
        _ = EnsureInitializedAsync();
    }

    private void Hide()
    {
        _shown = false;

        // On mobile the picker animates closed, so it stays rendered (with a
        // closing class) until the animation finishes. Desktop hides instantly.
        if (AnimateClose && DeviceInfo.IsMobile)
        {
            _hiding = true;
            _hideCts?.Cancel();
            _hideCts = new CancellationTokenSource();
            _ = FinishHideAsync(_hideCts.Token);
        }

        StateHasChanged();
    }

    private async Task FinishHideAsync(CancellationToken ct)
    {
        // Matches the emoji-picker-drop animation duration (--duration-slow)
        await Task.Delay(300);
        if (ct.IsCancellationRequested)
            return;

        _hiding = false;
        StateHasChanged();
    }

    public async Task<List<EmojiClickEvent>> SearchAsync(string query, int maxResults = 10)
    {
        if (_module is null || string.IsNullOrWhiteSpace(query))
            return new();

        var results = await _module.InvokeAsync<EmojiClickEvent[]>("search", query, maxResults);
        return results?.ToList() ?? new();
    }

    private const string ModulePath = "./_content/Valour.Client/Components/Utility/EmojiMart/EmojiMart.razor.js";

    /// <summary>
    /// Returns the user's most frequently used emojis from emoji-mart's own store,
    /// padded with defaults when there isn't enough history.
    /// </summary>
    public static async Task<List<EmojiClickEvent>> GetFrequentlyUsedAsync(IJSRuntime js, int maxResults = 6)
    {
        try
        {
            var module = await js.InvokeAsync<IJSObjectReference>("import", ModulePath);
            var results = await module.InvokeAsync<EmojiClickEvent[]>("getFrequent", maxResults);
            return results?.ToList() ?? new();
        }
        catch (JSException)
        {
            // Emoji library not loaded (e.g. CDN slow/blocked); show no quick reactions
            return new();
        }
    }

    /// <summary>
    /// Records an emoji use into emoji-mart's frequency store, for reactions added outside the picker.
    /// </summary>
    public static async Task RecordFrequentAsync(IJSRuntime js, string emojiId)
    {
        if (string.IsNullOrWhiteSpace(emojiId))
            return;

        try
        {
            var module = await js.InvokeAsync<IJSObjectReference>("import", ModulePath);
            await module.InvokeVoidAsync("recordFrequent", emojiId);
        }
        catch (JSException)
        {
            // Frequency tracking is best-effort; never crash the caller
        }
    }

    public async Task SetCustomEmojisAsync(
        IEnumerable<EmojiClickEvent>? emojis,
        string? customCategoryIcon = null,
        string? customCategoryName = null)
    {
        _customEmojis = emojis?.ToList() ?? new();
        _customCategoryIcon = customCategoryIcon ?? string.Empty;
        _customCategoryName = string.IsNullOrWhiteSpace(customCategoryName) ? "Planet" : customCategoryName;

        if (_module is not null)
        {
            await _module.InvokeVoidAsync("setCustom", _id, _customEmojis, _customCategoryIcon, _customCategoryName);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && StartShown)
            await EnsureInitializedAsync();
    }

    private Task EnsureInitializedAsync()
    {
        return _initializationTask ??= InitializeCoreAsync();
    }

    private async Task InitializeCoreAsync()
    {
        _dotNetReference = DotNetObjectReference.Create(this);
        _module = await JsRuntime.InvokeAsync<IJSObjectReference>("import", ModulePath);
        await _module.InvokeVoidAsync("init", _id, _dotNetReference, EmojiSet, _customEmojis, _customCategoryIcon, _customCategoryName);
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        try
        {
            if (_module is not null)
            {
                await _module.InvokeVoidAsync("destroy", _id);
                await _module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException) { }
        catch (JSException) { }

        _dotNetReference?.Dispose();
    }

    [JSInvokable]
    public async Task EmojiClick(EmojiClickEvent e)
    {
        if (OnEmojiClick is not null)
            await OnEmojiClick.Invoke(e);
    }

    [JSInvokable]
    public async Task ClickOutside(OutsidePickerClickEvent e)
    {
        if (!_shown)
            return;

        if (OnClickOutside is not null)
            await OnClickOutside.Invoke(e);
    }
}
