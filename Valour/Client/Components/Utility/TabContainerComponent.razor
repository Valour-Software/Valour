<div class="v-tab-container @(_sizeClass)">
    <div class="v-tab-header">
        <div class="v-tab-indicator" style="width: calc(100% / @_tabCount); transform: translateX(@(_active * 100)%);">
            <div class="v-tab-indicator-bar"></div>
        </div>
        @if (TabOne is not null)
        {
            <div class="v-tab @GetPositionClass(0) @GetActive(0)" @onclick="() => OnClick(0)">
                @if (!string.IsNullOrEmpty(IconOne))
                {
                    <i class="bi bi-@IconOne v-tab-icon"></i>
                }
                <span>@_titleOne</span>
                @if (BadgeOne.HasValue && BadgeOne.Value > 0)
                {
                    <span class="v-tab-badge">@BadgeOne</span>
                }
            </div>
        }
        @if (TabTwo is not null)
        {
            <div class="v-tab @GetPositionClass(1) @GetActive(1)" @onclick="() => OnClick(1)">
                @if (!string.IsNullOrEmpty(IconTwo))
                {
                    <i class="bi bi-@IconTwo v-tab-icon"></i>
                }
                <span>@_titleTwo</span>
                @if (BadgeTwo.HasValue && BadgeTwo.Value > 0)
                {
                    <span class="v-tab-badge">@BadgeTwo</span>
                }
            </div>
        }
        @if (TabThree is not null)
        {
            <div class="v-tab @GetPositionClass(2) @GetActive(2)" @onclick="() => OnClick(2)">
                @if (!string.IsNullOrEmpty(IconThree))
                {
                    <i class="bi bi-@IconThree v-tab-icon"></i>
                }
                <span>@_titleThree</span>
                @if (BadgeThree.HasValue && BadgeThree.Value > 0)
                {
                    <span class="v-tab-badge">@BadgeThree</span>
                }
            </div>
        }
        @if (TabFour is not null)
        {
            <div class="v-tab @GetPositionClass(3) @GetActive(3)" @onclick="() => OnClick(3)">
                @if (!string.IsNullOrEmpty(IconFour))
                {
                    <i class="bi bi-@IconFour v-tab-icon"></i>
                }
                <span>@_titleFour</span>
                @if (BadgeFour.HasValue && BadgeFour.Value > 0)
                {
                    <span class="v-tab-badge">@BadgeFour</span>
                }
            </div>
        }
        @if (TabFive is not null)
        {
            <div class="v-tab @GetPositionClass(4) @GetActive(4)" @onclick="() => OnClick(4)">
                @if (!string.IsNullOrEmpty(IconFive))
                {
                    <i class="bi bi-@IconFive v-tab-icon"></i>
                }
                <span>@_titleFive</span>
                @if (BadgeFive.HasValue && BadgeFive.Value > 0)
                {
                    <span class="v-tab-badge">@BadgeFive</span>
                }
            </div>
        }
        @if (TabSix is not null)
        {
            <div class="v-tab @GetPositionClass(5) @GetActive(5)" @onclick="() => OnClick(5)">
                @if (!string.IsNullOrEmpty(IconSix))
                {
                    <i class="bi bi-@IconSix v-tab-icon"></i>
                }
                <span>@_titleSix</span>
                @if (BadgeSix.HasValue && BadgeSix.Value > 0)
                {
                    <span class="v-tab-badge">@BadgeSix</span>
                }
            </div>
        }
    </div>
    <div class="v-tab-content" style="max-height: @MaxHeight; @ContentStyle">
        <SlideSwap Index="@_active" Subtle="true" Content="@ActiveContent" />
    </div>
</div>


@code {

    private string GetActive(int index)
    {
        return index == _active ? "active" : "";
    }
    
    [Parameter]
    public string ContentStyle { get; set; }

    /// <summary>
    /// Size variant: null/empty for default, "small" for compact tabs.
    /// </summary>
    [Parameter]
    public string Size { get; set; }

    private string _sizeClass => string.IsNullOrEmpty(Size) ? "" : $"v-tab-{Size}";

    [Parameter]
    public string[] Titles { get; set; }
    
    [Parameter]
    public string MaxHeight { get; set; } = "400px";
    
    [Parameter]
    public string IconOne { get; set; }

    [Parameter]
    public string IconTwo { get; set; }

    [Parameter]
    public string IconThree { get; set; }

    [Parameter]
    public string IconFour { get; set; }

    [Parameter]
    public string IconFive { get; set; }

    [Parameter]
    public string IconSix { get; set; }

    [Parameter]
    public int? BadgeOne { get; set; }

    [Parameter]
    public int? BadgeTwo { get; set; }

    [Parameter]
    public int? BadgeThree { get; set; }

    [Parameter]
    public int? BadgeFour { get; set; }

    [Parameter]
    public int? BadgeFive { get; set; }

    [Parameter]
    public int? BadgeSix { get; set; }

    private string GetPositionClass(int index)
    {
        if (index == 0) return "first";
        if (index == _tabCount - 1) return "last";
        return "";
    }

    // Cached so we don't have to keep recalculating
    private string _titleOne = "Tab One";
    private string _titleTwo = "Tab Two";
    private string _titleThree = "Tab Three";
    private string _titleFour = "Tab Four";
    private string _titleFive = "Tab Five";
    private string _titleSix = "Tab Six";


    [Parameter]
    public RenderFragment TabOne { get; set; }
    [Parameter]
    public RenderFragment TabTwo { get; set; }
    [Parameter]
    public RenderFragment TabThree { get; set; }
    [Parameter]
    public RenderFragment TabFour { get; set; }
    [Parameter]
    public RenderFragment TabFive { get; set; }
    [Parameter]
    public RenderFragment TabSix { get; set; }

    private int _tabCount;
    private int _active;

    protected override void OnInitialized()
    {
        if (TabOne is not null)
            _tabCount++;
        if (TabTwo is not null)
            _tabCount++;
        if (TabThree is not null)
            _tabCount++;
        if (TabFour is not null)
            _tabCount++;
        if (TabFive is not null)
            _tabCount++;
        if (TabSix is not null)
            _tabCount++;

        if (Titles is not null)
        {
            if (Titles.Length > 0)
                _titleOne = Titles[0];
            if (Titles.Length > 1)
                _titleTwo = Titles[1];
            if (Titles.Length > 2)
                _titleThree = Titles[2];
            if (Titles.Length > 3)
                _titleFour = Titles[3];
            if (Titles.Length > 4)
                _titleFive = Titles[4];
            if (Titles.Length > 5)
                _titleSix = Titles[5];
        }
    }

    private RenderFragment ActiveContent => _active switch
    {
        0 => TabOne,
        1 => TabTwo,
        2 => TabThree,
        3 => TabFour,
        4 => TabFive,
        _ => TabSix
    };

    private void OnClick(int index)
    {
        _active = index;
    }

}