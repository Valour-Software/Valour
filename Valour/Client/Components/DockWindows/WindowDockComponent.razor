@implements IAsyncDisposable
@inject ValourClient InjectedClient
@inject IAppStorage LocalStorage
@inject IJSRuntime JsRuntime
@using Valour.Client.Pages

<div class="window-dock" @ref="@_ref">
    @foreach (var tab in Tabs)
    {
        <WindowComponent @key="@tab.Id" WindowTab="@tab" Dock="@this" />
    }
    
    @foreach(var split in Splits)
    {
        <WindowSplitComponent @key="@split.Id" Split="@split" />
    }
</div>

@code {
    
    [Parameter]
    public StartScreenData StartData { get; set; }
    
    public ValourClient Client { get; private set; }
    
    public WindowLayout Layout { get; private set; }

    public List<WindowTab> Tabs { get; private set; } = new();

    public List<WindowSplit> Splits { get; private set; } = new();
    
    public ElementDimensions Dimensions { get; private set; }

    private ResizeObserver _resizeObserver;
    
    private ElementReference _ref;
    
    // Floaters are not tracked by a layout, so they are stored here
    private List<WindowTab> _floaters = new();

    private WindowSaveLoadAdapter _saveLoadAdapter;

    protected override async Task OnInitializedAsync()
    {
        Client = InjectedClient;
        
        _saveLoadAdapter = new(Client);
        
        WindowService.AddDock(this);

        var loaded = false;
        
        // check if state is saved
        var layoutJson = await LocalStorage.GetStringAsync("coreLayout");
        if (!string.IsNullOrWhiteSpace(layoutJson))
        {
            try
            {
                Layout = await _saveLoadAdapter.DeserializeLayout(layoutJson);
                Layout.SetDockRecursiveRaw(this);

                // If every saved tab failed to restore, fall back to home
                // rather than showing an empty/broken dock
                var restoredTabs = new List<WindowTab>();
                Layout.GetTabs(restoredTabs);
                if (restoredTabs.Count == 0)
                {
                    Console.WriteLine("Saved layout had no restorable tabs; resetting to home.");
                    await Reset();
                }
            }
            catch (Exception e)
            {
                Console.WriteLine("Failed to load saved layout: " + e.Message);
                await Reset();
            }

            loaded = true;
        }

        if (!DeviceInfo.IsMobile)
        {
            var floatersJson = await LocalStorage.GetStringAsync("coreFloaters");
            if (!string.IsNullOrWhiteSpace(floatersJson))
            {
                try
                {
                    _floaters = await _saveLoadAdapter.DeserializeFloaters(floatersJson);
                }
                catch (Exception e)
                {
                    Console.WriteLine("Failed to load saved floaters: " + e.Message);
                    _floaters.Clear();
                }
            }
        }

        if (!loaded)
        {
            await Reset();
        }
        else
        {
            Layout.RecalculatePosition();
            await NotifyLayoutChanged(false, false);
            Layout.ReRenderRecursive();
        }

        await TryOpenStartTargetAsync();
    }

    /// <summary>
    /// Honors deep links (/planetchannels/..., /directchannels/..., and /planetthreads/...)
    /// by opening the target channel or thread, optionally focused on a specific message.
    /// </summary>
    private async Task TryOpenStartTargetAsync()
    {
        if (StartData?.Start is null)
            return;

        if (StartData.Start == StartScreen.PlanetThread)
        {
            await TryOpenStartThreadAsync();
            return;
        }

        if (StartData.StartChannelId is null)
            return;

        try
        {
            Channel channel = null;

            switch (StartData.Start)
            {
                case StartScreen.PlanetChannel:
                {
                    if (StartData.StartPlanetId is null)
                        return;

                    var planet = await Client.PlanetService.FetchPlanetAsync(StartData.StartPlanetId.Value);
                    if (planet is null)
                        return;

                    channel = await Client.ChannelService.FetchPlanetChannelAsync(StartData.StartChannelId.Value, planet);
                    break;
                }
                case StartScreen.DirectChannel:
                {
                    channel = await Client.ChannelService.FetchDirectChannelAsync(StartData.StartChannelId.Value);
                    break;
                }
            }

            if (channel is null)
                return;

            var content = await ChatWindowComponent.GetDefaultContent(channel);

            if (StartData.StartMessageId is not null && StartData.StartMessageId.Value != 0)
                content.TargetMessageId = StartData.StartMessageId;

            await Layout.AddTab(content);
            await NotifyLayoutChanged();
        }
        catch (Exception e)
        {
            Console.WriteLine("Failed to open deep-linked channel: " + e.Message);
        }
    }

    private async Task TryOpenStartThreadAsync()
    {
        if (StartData.StartPlanetId is null)
            return;

        try
        {
            // No thread id means the link targets the planet's thread feed
            if (StartData.StartThreadId is null)
            {
                var planet = await Client.PlanetService.FetchPlanetAsync(StartData.StartPlanetId.Value);
                if (planet is null)
                    return;

                await Layout.AddTab(ThreadsWindowComponent.GetDefaultContent(planet));
                await NotifyLayoutChanged();
                return;
            }

            var thread = await Client.ThreadService.FetchThreadAsync(
                StartData.StartPlanetId.Value,
                StartData.StartThreadId.Value);

            if (thread is null)
                return;

            var content = ThreadWindowComponent.GetDefaultContent(thread);
            await Layout.AddTab(content);
            await NotifyLayoutChanged();
        }
        catch (Exception e)
        {
            Console.WriteLine("Failed to open deep-linked thread: " + e.Message);
        }
    }

    /// <summary>
    /// Notifies this dock that the layout has changed.
    /// This will update the tabs and splits, and re-render if necessary.
    /// </summary>
    public async Task NotifyLayoutChanged(bool notifyService = true, bool saveLayout = true)
    {
        // Clear old lists
        Tabs.Clear();
        Splits.Clear();

        // Get new tabs and splits
        Layout.GetTabs(Tabs);
        Tabs.AddRange(_floaters);

        Layout.GetSplits(Splits);

        if (notifyService)
        {
            // Notify global window service
            WindowService.NotifyDockLayoutUpdated();
        }

        // Actually render changes
        Render();

        // Save layout
        await SaveLayout();

        // Save floaters
        await SaveFloaters();
    }
    
    public async Task AddFloatingTab(WindowContent content, FloatingWindowProps floatingProps)
    {
        var tab = new WindowTab(content, floatingProps);
        await AddFloatingTab(tab, floatingProps);
    }
    
    /// <summary>
    /// Adds a tab as a floating window.
    /// </summary>
    public async Task AddFloatingTab(WindowTab tab, FloatingWindowProps floatingProps)
    {
        if (floatingProps is null)
        {
            floatingProps = new FloatingWindowProps()
            {
                // Center window with half size
                X = BrowserUtils.WindowDimensions.Width / 4f,
                Y = BrowserUtils.WindowDimensions.Height / 4f,
                Width = BrowserUtils.WindowDimensions.Width / 2,
                Height = BrowserUtils.WindowDimensions.Height / 2
            };
        }
        
        // this HAS to happen first to prevent component re-initialization
        _floaters.Add(tab);
        
        tab.SetFloatingProps(floatingProps);
        
        await tab.SetLayout(null);

        await NotifyLayoutChanged();
    }

    public async Task RemoveFloatingTab(WindowContent content)
    {
        var tab = content.Tab;
        if (tab is not null)
        {
            await RemoveFloatingTab(tab);
        }
    }
    
    public async Task RemoveFloatingTab(WindowTab tab)
    {
        await tab.NotifyClose();
        
        tab.SetFloatingProps(null);
        _floaters.Remove(tab);
        await NotifyLayoutChanged();
    }

    public async Task Reset(bool notifyService = true, bool saveLayout = true)
    {
        _floaters.Clear();
        Tabs.Clear();
        Splits.Clear();

        Layout = new WindowLayout(this);
        await Layout.AddTab(ThreadsWindowComponent.DefaultContent);

        await NotifyLayoutChanged(notifyService, saveLayout);
    }
    
    public async Task SaveLayout()
    {
        var layoutJson = _saveLoadAdapter.SerializeLayout(Layout);
        // Console.WriteLine(layoutJson);
        await LocalStorage.SetStringAsync("coreLayout", layoutJson);
    }

    public async Task SaveFloaters()
    {
        var floatersJson = _saveLoadAdapter.SerializeFloaters(_floaters);
        await LocalStorage.SetStringAsync("coreFloaters", floatersJson);
    }

    
    // Rendering //
    
    /// <summary>
    /// Flag that allows or disallows rendering.
    /// </summary>
    private bool _canRender = true;
    
    protected override bool ShouldRender() => _canRender;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _canRender = false;
        
        if (firstRender)
        {
            _resizeObserver = new ResizeObserver();
            _resizeObserver.ResizeEvent += OnWindowResize;
            await _resizeObserver.Initialize(_ref, JsRuntime, 3);
        }

        await RefreshSize();
    }
    
    private void Render()
    {
        _canRender = true;
        InvokeAsync(StateHasChanged);
    }
    
    private void OnWindowResize(ElementDimensions d)
    {
        Dimensions = d;
    }

    private async Task RefreshSize()
    {
        Dimensions = await BrowserUtils.GetElementDimensions(_ref);
    }
    
    public async ValueTask DisposeAsync()
    {
        if (_resizeObserver is not null)
            await _resizeObserver.DisposeAsync();
    }

}