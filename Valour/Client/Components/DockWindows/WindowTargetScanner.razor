@*
    This component is used to scan for the window drop targets.
    It's challenging to scan under an element, so we use some
    JS interop to handle it.
*@

@inject IJSRuntime JsRuntime

@code {
    private static IJSObjectReference JsModule { get; set; }
    public static IJSObjectReference JsService { get; private set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            JsModule = await JsRuntime.InvokeAsync<IJSObjectReference>("import", "./_content/Valour.Client/Components/DockWindows/WindowTargetScanner.razor.js");
            JsService = await JsModule.InvokeAsync<IJSObjectReference>("init");
        }
    }
    
    public static async Task ScanAsync(float x, float y)
    {
        await JsService.InvokeVoidAsync("scan", x, y);
    }

    public static async Task<bool> FinalizeAsync(float x, float y)
    {
        return await JsService.InvokeAsync<bool>("finalize", x, y);
    }

}