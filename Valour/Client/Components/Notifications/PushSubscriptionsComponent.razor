@using Valour.Client.Notifications
@implements IDisposable
@inject IPushNotificationService PushService
@inject ValourClient Client
@inject IAppStorage Storage

@code {

    public static PushSubscriptionsComponent Instance;

    // Renewal is a cheap POST, but no need to spam it on every window focus
    private static readonly TimeSpan RenewInterval = TimeSpan.FromHours(6);
    private const string LastRenewalKeyPrefix = "push-subscription-last-renewal";
    private readonly SemaphoreSlim _renewalLock = new(1, 1);
    private DateTime _lastRenewalAttempt = DateTime.MinValue;

    protected override void OnInitialized()
    {
        Instance = this;

        // On native the app process can live for weeks without a cold start,
        // so renew on resume/refocus too - not just on first render.
        BrowserUtils.Focused += OnAppFocused;
        Client.NotificationService.NotificationReceived += OnNotificationReceived;
        Client.NotificationService.NotificationsCleared += OnNotificationsCleared;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await TryRenewSubscriptionAsync();
    }

    private async Task OnAppFocused()
    {
        await TryRenewSubscriptionAsync();
    }

    /// <summary>
    /// If the user is logged in and previously opted into push notifications,
    /// re-subscribes to keep the server-side subscription alive (it expires if
    /// not renewed) and to recover when an earlier subscription attempt failed.
    /// Requires no user gesture: permission is already granted at this point.
    /// </summary>
    private async Task TryRenewSubscriptionAsync()
    {
        await _renewalLock.WaitAsync();
        try
        {
            await TryRenewSubscriptionCoreAsync();
        }
        finally
        {
            _renewalLock.Release();
        }
    }

    private async Task TryRenewSubscriptionCoreAsync()
    {
        // Instance has no push backend configured — nothing to renew against
        if (Client.InstanceManifest is not null && !Client.InstanceManifest.Capabilities.PushNotifications)
            return;

        if (DateTime.UtcNow - _lastRenewalAttempt < RenewInterval)
            return;

        try
        {
            if (!Client.IsLoggedIn || !await PushService.IsNotificationsEnabledAsync())
                return;

            var renewalKey = $"{LastRenewalKeyPrefix}-{Client.Me.Id}";
            var persisted = await Storage.GetStringAsync(renewalKey);
            if (DateTimeOffset.TryParse(persisted, out var lastRenewal) &&
                DateTimeOffset.UtcNow - lastRenewal < RenewInterval)
                return;

            _lastRenewalAttempt = DateTime.UtcNow;
            var result = await PushService.RequestSubscriptionAsync();
            if (result.Success)
                await Storage.SetStringAsync(renewalKey, DateTimeOffset.UtcNow.ToString("O"));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Push subscription renewal failed: {ex.Message}");
        }
    }

    public void Dispose()
    {
        BrowserUtils.Focused -= OnAppFocused;
        Client.NotificationService.NotificationReceived -= OnNotificationReceived;
        Client.NotificationService.NotificationsCleared -= OnNotificationsCleared;
        _renewalLock.Dispose();
    }

    private Task OnNotificationReceived(Notification notification)
        => notification.TimeRead is null
            ? Task.CompletedTask
            : PushService.DismissNotificationAsync(notification.Id, notification.SourceId);

    private Task OnNotificationsCleared()
        => PushService.DismissAllNotificationsAsync();

    public Task<PushSubscriptionResult> RequestSubscriptionAsync()
        => PushService.RequestSubscriptionAsync();

    public Task UnsubscribeAsync()
        => PushService.UnsubscribeAsync();

    public Task<PushSubscriptionResult> GetSubscriptionAsync()
        => PushService.GetSubscriptionAsync();

    public Task<bool> IsNotificationsEnabledAsync()
        => PushService.IsNotificationsEnabledAsync();

    public Task<string> GetPermissionStateAsync()
        => PushService.GetPermissionStateAsync();

    public Task AskForPermissionAsync()
        => PushService.AskForPermissionAsync();

    public Task OpenNotificationSettingsAsync()
        => PushService.OpenNotificationSettingsAsync();
}
