    private async Task ScrollToHeadingAsync(int index)
    {
        await JsRuntime.InvokeVoidAsync("wikiScrollToHeading", ContentContainerId, index);
    }

    /// <summary>
    /// Fence-aware extraction of h2/h3 headings from markdown. Matches the
    /// rendered heading order, which is what wikiScrollToHeading targets.
    /// </summary>
    private static List<(int Level, string Text)> ComputeToc(string markdown)
    {
        var result = new List<(int, string)>();
        if (string.IsNullOrEmpty(markdown))
            return result;

        var inFence = false;
        foreach (var rawLine in markdown.Split('\n'))
        {
            var line = rawLine.TrimStart();
            if (line.StartsWith("```") || line.StartsWith("~~~"))
            {
                inFence = !inFence;
                continue;
            }

            if (inFence)
                continue;

            if (line.StartsWith("### "))
                result.Add((3, line[4..].Trim()));
            else if (line.StartsWith("## "))
                result.Add((2, line[3..].Trim()));
        }

        return result;
    }

    ////////////////////
    // Window content //
    ////////////////////

    public class Content : WindowContent<WikiWindowComponent, WikiWindowData>
    {
        public override async Task ImportData(string data, ValourClient client)
        {
            Data = JsonSerializer.Deserialize<WikiWindowData>(data);
            if (Data is not null)
            {
                var planet = await client.PlanetService.FetchPlanetAsync(Data.PlanetId);
                if (planet is not null)
                {
                    Title = "Wiki - " + planet.Name;
                    Icon = planet.GetIconUrl(IconFormat.Webp64);
                    PlanetId = planet.Id;
                }
            }
        }

        public override string ExportData(ValourClient client)
        {
            return JsonSerializer.Serialize(Data);
        }
    }

    public static Content GetDefaultContent(Planet planet, long? pageId = null)
    {
        return new Content()
        {
            Title = "Wiki - " + planet.Name,
            Icon = planet.GetIconUrl(IconFormat.Webp64),
            Data = new WikiWindowData
            {
                PlanetId = planet.Id,
                SelectedPageId = pageId,
            },
            PlanetId = planet.Id,
        };
    }

    public void Dispose()
    {
        if (Instances.Remove(this))
            SelectionsChanged?.Invoke();

        if (_planet is not null)
        {
            _planet.WikiPages.Changed -= OnDocsChanged;
            _planet.Updated -= OnPlanetUpdated;
        }
    }
}
