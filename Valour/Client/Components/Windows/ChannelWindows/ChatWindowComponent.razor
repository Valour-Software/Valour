    [JSInvokable("OnScrollBottomInvoke")]
    public async Task OnScrollBottom()
    {
        if (DateTime.UtcNow < _suppressBottomPagingUntil)
            return;

        if (_isCaughtUp || _loadingForward)
            return;

        if (_loadingBackward || _scaleScrollAfterNextRender || _trimBottomAfterScale || _trimTopAfterNextRender)
            return;

        if (DisplayedMessages == null || DisplayedMessages.Count == 0)
            return;

        await LoadNextPageAsync();
    }

    private async Task LoadNextPageAsync()
    {
        if (Channel is null || DisplayedMessages.Count == 0)
            return;

        _loadingForward = true;

        try
        {
            var lastId = DisplayedMessages[^1].Id;
            var beforeCount = DisplayedMessages.Count;
            var messages = await Channel.GetMessagesAfterAsync(lastId, MessagePageSize);

            if (messages is null || messages.Count == 0)
            {
                _isCaughtUp = true;
                return;
            }

            await AddMessages(messages, render: false, scroll: false);

            if (messages.Count < MessagePageSize)
                _isCaughtUp = true;

            if (DisplayedMessages.Count == beforeCount)
                return;

            _trimTopAfterNextRender = DisplayedMessages.Count > TrimThreshold;
            await ReRender();
        }
        finally
        {
            if (!_trimTopAfterNextRender && !_scaleScrollAfterNextRender)
                _loadingForward = false;
        }
    }

    private async Task LoadLatestWindowAsync()
    {
        if (Channel is null)
            return;

        _loadingForward = true;

        try
        {
            var queuedMessages = QueuedMessages.ToList();
            var messages = await Channel.GetLastMessagesAsync(MessagePageSize);

            if (messages is not { Count: > 0 })
                return;

            _isCaughtUp = true;
            ClearMessages(false);

            await AddMessages(messages, render: false, scroll: false);

            if (queuedMessages.Count > 0)
            {
                var fingerprints = DisplayedMessages
                    .Where(x => !string.IsNullOrEmpty(x.Fingerprint))
                    .Select(x => x.Fingerprint)
                    .ToHashSet();

                QueuedMessages.AddRange(queuedMessages.Where(x =>
                    string.IsNullOrEmpty(x.Fingerprint) || !fingerprints.Contains(x.Fingerprint)));
            }

            _showJumpToBottom = false;
            _scrollLatestWindowAfterNextRender = true;
            await ReRender();
        }
        finally
        {
            _loadingForward = false;
        }
    }

    [JSInvokable("OnDebouncedScroll")]
