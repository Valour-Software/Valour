    }

    [JSInvokable("OnBottomStickinessChanged")]
    public async Task OnBottomStickinessChanged(bool isAtBottom)
    {
        var shouldShowJumpButton = !isAtBottom;
        if (_showJumpToBottom == shouldShowJumpButton)
            return;

        _showJumpToBottom = shouldShowJumpButton;
        await ReRender();
    }

    private void TrimMessagesFromBottom()
    {
        if (DisplayedMessages.Count <= TrimThreshold)
            return;

        var excess = DisplayedMessages.Count - TargetMessages;
        if (excess <= 0)
            return;

        DisplayedMessages.RemoveRange(DisplayedMessages.Count - excess, excess);
        _isCaughtUp = false;
        _suppressBottomPagingUntil = DateTime.UtcNow.AddMilliseconds(600);
    }

    private void TrimMessagesFromTop()
    {
        if (DisplayedMessages.Count <= TrimThreshold)
            return;

        var excess = DisplayedMessages.Count - TargetMessages;
        if (excess <= 0)
            return;

        DisplayedMessages.RemoveRange(0, excess);
    }
    

    [JSInvokable("OnScrollTopInvoke")]
    public async Task OnScrollTop()
    {
        _scrollLatestWindowAfterNextRender = false;

        if (_loadingBackward)
            return;

        if (DisplayedMessages == null ||
            DisplayedMessages.Count == 0)
        {
            return;
        }

        _loadingBackward = true;

        try
        {
            var firstId = DisplayedMessages[0].Id;

            Client.Logger.Log<ChatWindowComponent>($"Fetching older messages from id {firstId} for window {WindowCtx.Id}", "cyan");

            var messages = await Channel.GetMessagesAsync(firstId, MessagePageSize);

            if (messages is null || !messages.Any())
                return;

            // Insert older messages above, then preserve the viewport after the DOM has rendered them.
            await UpdateScrollPosition();
            DisplayedMessages.InsertRange(0, messages);
            _scaleScrollAfterNextRender = true;
            _trimBottomAfterScale = DisplayedMessages.Count > TrimThreshold;
            await ReRender();
        }
        finally
        {
            if (!_scaleScrollAfterNextRender)
                _loadingBackward = false;
        }
    }
    
