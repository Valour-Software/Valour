<div class="header-row">
    <div class="h-left">
        <ChannelWatchingComponent Channel="@Channel" ParentComponent="@ChatComponent" />
    </div>
    <div class="h-center">
        <input @onmousedown="@OnClickSearchBar" @oninput="@OnSearchChange" type="search" class="form-control @(_searchVisible ? "open" : "closed")" placeholder="Search..." />
        @if (_searchResults.Count > 0)
        {
            <div @onclick="@CloseSearch" class="search-backdrop"></div>
            <div class="search-results glassy-modal">
                <div class="results-scroll">
                    @SearchMessagesFragment
                </div>
            </div>
        }
    </div>
    <div class="h-right">
        <TooltipTrigger Position="left">
            <ChildContent>
                <div @onclick="@OnClickSearch" type="button" tabindex="0" class="search-btn">
                    <i class="bi bi-search"></i>
                </div>
            </ChildContent>
            <TooltipContent>
                <span>
                    Search
                </span>
            </TooltipContent>
        </TooltipTrigger>
        <TooltipTrigger Position="left">
            <ChildContent>
                <div @onclick="@OnClickMembers" type="button" tabindex="0" class="members-btn">
                    <i class="bi bi-people-fill"></i>
                </div>
            </ChildContent>
            <TooltipContent>
                <span>
                    Members
                </span>
            </TooltipContent>
        </TooltipTrigger>
        <TooltipTrigger Position="left">
            <ChildContent>
                <div @onclick="@OnClickSettings" type="button" tabindex="0" class="settings-btn">
                    <i class="bi bi-gear-fill"></i>
                </div>
            </ChildContent>
            <TooltipContent>
                <span>
                    Settings
                </span>
            </TooltipContent>
        </TooltipTrigger>
        @if (_settingsVisible)
        {
            <div @onclick="@CloseSettings" class="search-backdrop"></div>
            <div class="settings-results glassy-modal">
                <div class="settings-header">Chat Settings</div>

                <div class="channel-setting" @onclick="@OnClickGhostTyping">
                    <div class="setting-icon"><i class="bi @(ClientFlags.GhostTyping ? "bi-eye-slash-fill" : "bi-eye-fill")"></i></div>
                    <div class="setting-text">
                        <span class="setting-title">Ghost Typing</span>
                        <span class="setting-subtitle">Hide that you're typing from others</span>
                    </div>
                    <div class="toggle-switch @(ClientFlags.GhostTyping ? "on" : "")">
                        <div class="toggle-knob"></div>
                    </div>
                </div>

                <div class="channel-setting" @onclick="@OnClickShowDeletedMessages">
                    <div class="setting-icon"><i class="bi bi-trash3-fill"></i></div>
                    <div class="setting-text">
                        <span class="setting-title">Show Deleted Messages</span>
                        <span class="setting-subtitle">Keep deleted messages visible, marked in red</span>
                    </div>
                    <div class="toggle-switch @(ClientFlags.ShowDeletedMessages ? "on" : "")">
                        <div class="toggle-knob"></div>
                    </div>
                </div>

                <div class="channel-setting" @onclick="@OnClickShowEditHistory">
                    <div class="setting-icon"><i class="bi bi-clock-history"></i></div>
                    <div class="setting-text">
                        <span class="setting-title">Show Edit History</span>
                        <span class="setting-subtitle">Display previous versions of edited messages</span>
                    </div>
                    <div class="toggle-switch @(ClientFlags.ShowEditHistory ? "on" : "")">
                        <div class="toggle-knob"></div>
                    </div>
                </div>

                <div class="channel-setting" @onclick="@OnClickShowModdedBadge">
                    <div class="setting-icon"><i class="bi bi-joystick"></i></div>
                    <div class="setting-text">
                        <span class="setting-title">Modded Client Badge</span>
                        <span class="setting-subtitle">Let other modded client users see that you're one too</span>
                    </div>
                    <div class="toggle-switch @(ClientFlags.ShowModdedBadge ? "on" : "")">
                        <div class="toggle-knob"></div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool _searchVisible = false;
    private bool _settingsVisible = false;

    [Parameter]
    public Channel Channel { get; set; }

    [Parameter]
    public ChatWindowComponent ChatComponent { get; set; }

    [Inject]
    public IAppStorage LocalStorage { get; set; }

    [Inject]
    public ValourClient Client { get; set; }

    [Inject]
    public IJSRuntime JsRuntime { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (await LocalStorage.ContainsKeyAsync("ghost-typing"))
            ClientFlags.GhostTyping = await LocalStorage.GetAsync<bool>("ghost-typing");

        if (await LocalStorage.ContainsKeyAsync("show-deleted-messages"))
            ClientFlags.ShowDeletedMessages = await LocalStorage.GetAsync<bool>("show-deleted-messages");

        if (await LocalStorage.ContainsKeyAsync("show-edit-history"))
            ClientFlags.ShowEditHistory = await LocalStorage.GetAsync<bool>("show-edit-history");

        if (await LocalStorage.ContainsKeyAsync("show-modded-badge"))
            ClientFlags.ShowModdedBadge = await LocalStorage.GetAsync<bool>("show-modded-badge");

        // Always fetch the online list so everyone can see others' badges,
        // regardless of whether this user opts in to reporting their own.
        ModdedPresenceService.StartListRefresh(JsRuntime);

        if (ClientFlags.ShowModdedBadge && Client.Me is not null)
            ModdedPresenceService.StartReporting(Client.Me.Id, Client.Me.Name);
    }

    private void OnClickMembers()
    {
        ChatComponent.ToggleMembersList();
    }

    private void OnClickSettings()
    {
        _settingsVisible = !_settingsVisible;
        StateHasChanged();
    }

    private void CloseSettings()
    {
        _settingsVisible = false;
        StateHasChanged();
    }

    private async Task OnClickGhostTyping()
    {
        ClientFlags.GhostTyping = !ClientFlags.GhostTyping;
        await LocalStorage.SetAsync("ghost-typing", ClientFlags.GhostTyping);
        StateHasChanged();
    }

    private async Task OnClickShowDeletedMessages()
    {
        ClientFlags.ShowDeletedMessages = !ClientFlags.ShowDeletedMessages;
        await LocalStorage.SetAsync("show-deleted-messages", ClientFlags.ShowDeletedMessages);
        StateHasChanged();
    }

    private async Task OnClickShowEditHistory()
    {
        ClientFlags.ShowEditHistory = !ClientFlags.ShowEditHistory;
        await LocalStorage.SetAsync("show-edit-history", ClientFlags.ShowEditHistory);
        ClientFlags.NotifyChanged();
        StateHasChanged();
    }

    private async Task OnClickShowModdedBadge()
    {
        ClientFlags.ShowModdedBadge = !ClientFlags.ShowModdedBadge;
        await LocalStorage.SetAsync("show-modded-badge", ClientFlags.ShowModdedBadge);

        if (ClientFlags.ShowModdedBadge && Client.Me is not null)
        {
            ModdedPresenceService.StartReporting(Client.Me.Id, Client.Me.Name);
        }
        else
        {
            ModdedPresenceService.StopReporting();
        }

        StateHasChanged();
    }

    private void OnClickSearch()
    {
        _searchVisible = !_searchVisible;
        StateHasChanged();
    }
    
    private string _search = "";
    private string _storedSearch = "";
    private bool _searchLoading = false;
    private bool _searchQueued = false;

    private List<Message> _searchResults = new();

    private async Task OnSearchChange(ChangeEventArgs e)
    {
        await OnMessageSearch(e.Value.ToString());
    }
    
    private async Task OnMessageSearch(string search)
    {
        _search = search;

        if (string.IsNullOrWhiteSpace(_search))
        {
            _searchResults.Clear();
            StateHasChanged();
            
            return;
        }
        
        if (_searchLoading)
        {
            _searchQueued = true;
            return;
        }

        do
        {
            _searchLoading = true;
            _searchQueued = false;

            _searchResults = await Channel.SearchMessagesAsync(_search, 20);
            
            StateHasChanged();
            await Task.Delay(100); // Require at least 200ms between searches
            _searchLoading = false;
        } while (_searchQueued);
    }
    
    private RenderFragment SearchMessagesFragment => builder =>
    {
        // Displayed messages
        foreach (var message in _searchResults)
        {
            var msg = message; // capture for lambda

            var messageParams = new MessageComponent.Params()
            {
                ChatComponent = ChatComponent,
                Message = message,
                IsInnerReply = false,
                LastMessage = null,
                Ghost = false,
            };

            // Wrapper div for result + jump button
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "search-result-item");
            builder.SetKey(message.Id);

            builder.OpenComponent<MessageComponent>(2);
            builder.AddAttribute(3, "ParamData", messageParams);
            builder.CloseComponent();

            builder.OpenElement(4, "div");
            builder.AddAttribute(5, "class", "jump-to-message");
            builder.AddAttribute(6, "onclick", EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.MouseEventArgs>(this, () => JumpToMessage(msg)));
            builder.AddContent(7, "Jump to message");
            builder.CloseElement();

            builder.CloseElement();
        }
    };

    private async Task JumpToMessage(Message message)
    {
        CloseSearch();
        await ChatComponent.LoadAroundMessageAsync(message.Id);
    }
    
    private void CloseSearch()
    {
        _searchVisible = false;
        _storedSearch = _search;
        _search = "";
        _searchResults.Clear();
        StateHasChanged();
    }
    
    private async Task OnClickSearchBar()
    {
        // Restore search if it was cleared
        if (string.IsNullOrWhiteSpace(_search) && !string.IsNullOrWhiteSpace(_storedSearch))
        {
            await OnMessageSearch(_storedSearch);
        }
    }
}