    public async ValueTask<List<EmojiClickEvent>> SearchEmojisAsync(string query, int maxResults = 10)
    {
        if (string.IsNullOrWhiteSpace(query))
            return new List<EmojiClickEvent>();

        List<EmojiClickEvent> native = _emojis is null
            ? new List<EmojiClickEvent>()
            : await _emojis.SearchAsync(query, maxResults);

        var custom = PlanetEmojiMapper.Search(ChatComponent?.Channel?.Planet, query, maxResults);
        if (custom.Count == 0)
            return native.Take(maxResults).ToList();

        var merged = custom
            .Concat(native)
            .GroupBy(x => x.IsCustom ? $"c-{x.CustomId ?? 0}" : $"n-{x.Unified ?? x.Native ?? x.Id}")
            .Select(x => x.First())
            .Take(maxResults)
            .ToList();

        return merged;
    }

    /// <summary>
    /// Finds an emoji whose shortcode exactly equals <paramref name="shortcode"/>
    /// (the text between the colons of a ":name:" token), or null if there is no
    /// exact match. Used to auto-fill a fully typed emote without a click.
    /// </summary>
    private async Task<EmojiClickEvent> FindExactEmojiAsync(string shortcode)
    {
        var candidates = await SearchEmojisAsync(shortcode, 25);
        return candidates.FirstOrDefault(e => EmojiShortcodeMatches(e, shortcode));
    }

    private static bool EmojiShortcodeMatches(EmojiClickEvent emoji, string shortcode)
    {
        bool Matches(string value) => !string.IsNullOrEmpty(value)
            && string.Equals(value.Trim(':'), shortcode, StringComparison.OrdinalIgnoreCase);

        if (Matches(emoji.Id) || Matches(emoji.Name) || Matches(emoji.Shortcodes) || Matches(emoji.Token))
            return true;

        if (emoji.Aliases is not null)
        {
            foreach (var alias in emoji.Aliases)
            {
                if (Matches(alias))
                    return true;
            }
        }

        return false;
    }

    public ValueTask InjectEmojiForAutocompleteAsync(EmojiClickEvent emoji)
    {
        return InjectEmojiAsync(
            emoji.Id,
            emoji.Native,
            emoji.Unified,
            emoji.Shortcodes,
            true,
            true,
            emoji.IsCustom,
            emoji.Token,
            emoji.Src);
    }

