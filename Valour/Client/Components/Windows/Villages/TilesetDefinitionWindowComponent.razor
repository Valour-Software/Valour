    public class BrushDraft
    {
        public string Name { get; set; } = string.Empty;
        public string Key { get; set; } = string.Empty;
        public int Size { get; set; } = 3;
        public List<BrushCellDraft> Cells { get; set; } = CreateCells(3);

        public static BrushDraft CreateDefault() => new();

        public void Resize(int size)
        {
            size = Math.Max(1, size);
            if (size == Size && Cells.Count == Size * Size)
                return;

            var oldSize = Size;
            var oldCells = Cells.ToList();
            Size = size;
            Cells = CreateCells(size);

            var sharedSize = Math.Min(oldSize, size);
            var oldOffset = Math.Max(0, (oldSize - sharedSize) / 2);
            var newOffset = Math.Max(0, (size - sharedSize) / 2);
            for (var y = 0; y < sharedSize; y++)
            {
                for (var x = 0; x < sharedSize; x++)
                {
                    var oldIndex = (y + oldOffset) * oldSize + x + oldOffset;
                    var newIndex = (y + newOffset) * size + x + newOffset;
                    if (oldIndex >= 0 && oldIndex < oldCells.Count && newIndex >= 0 && newIndex < Cells.Count)
                        Cells[newIndex] = oldCells[oldIndex].Clone();
                }
            }
        }

        public BrushDraft Clone() => new()
        {
            Name = Name,
            Key = Key,
            Size = Size,
            Cells = Cells.Select(cell => cell.Clone()).ToList()
        };

        private static List<BrushCellDraft> CreateCells(int size)
        {
            var cells = new List<BrushCellDraft>();
            for (var i = 0; i < size * size; i++)
            {
                cells.Add(new BrushCellDraft
                {
                    Strength = GetDefaultBrushStrength(i, size)
                });
            }

            return cells;
        }
    }

