@inject ValourClient Client

@* Twitter-style composer that sits above the feed. Collapsed it's a
   compose bar; clicking expands it into the compose form inline.
   Open/close uses the same bottom-sheet pattern as the mobile emoji
   picker: the card stays rendered with a 'closing' class until the
   collapse animation finishes. *@

<div class="inline-compose">
    @if (_open || _closing)
    {
        <div class="compose-card @(_closing ? "closing" : "")">
            <div class="compose-card-header">
                <h4><i class="bi bi-rocket-takeoff-fill"></i> New Thread</h4>
            </div>
            <ThreadComposeForm Planet="@Planet"
                               OnPosted="@HandlePosted"
                               OnCancel="@Close"
                               Autofocus="true"/>
        </div>
    }
    @if (!_open)
    {
        <button class="compose-cta" @onclick="@Open">
            <img class="cta-avatar" src="@(Client.Me?.GetAvatar(AvatarFormat.Webp64))" alt="" loading="lazy"/>
            <span class="cta-placeholder">Start a new thread...</span>
            <span class="cta-post">
                <i class="bi bi-rocket-takeoff-fill"></i>
                New Post
            </span>
        </button>
    }
</div>

@code {
    /// <summary>
    /// Target planet for new threads. When null, the form shows a planet picker.
    /// </summary>
    [Parameter]
    public Planet Planet { get; set; }

    [Parameter]
    public Func<PlanetThread, Task> OnPosted { get; set; }

    private bool _open;
    private bool _closing;
    private CancellationTokenSource _closeCts;

    public void Open()
    {
        _closeCts?.Cancel();
        _closing = false;
        _open = true;
        StateHasChanged();
    }

    private void Close()
    {
        if (!_open)
            return;

        _open = false;
        _closing = true;
        _closeCts?.Cancel();
        _closeCts = new CancellationTokenSource();
        _ = FinishCloseAsync(_closeCts.Token);
        StateHasChanged();
    }

    private async Task FinishCloseAsync(CancellationToken ct)
    {
        // Matches the compose-collapse animation duration (--duration-slow)
        await Task.Delay(300);
        if (ct.IsCancellationRequested)
            return;

        _closing = false;
        StateHasChanged();
    }

    private async Task HandlePosted(PlanetThread thread)
    {
        Close();

        if (OnPosted is not null)
            await OnPosted.Invoke(thread);
    }
}
