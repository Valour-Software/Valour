@inherits ContextMenu<MessageContextMenu.MessageContextParams>
@inject IJSRuntime JsRuntime
@inject ValourClient Client
@inject NavigationManager NavManager
@using Valour.Client.Emojis

@if (_canUseReactions && _quickEmojis is not null && _quickEmojis.Count > 0)
{
    <div class="quick-reactions">
        @foreach (var emoji in _quickEmojis)
        {
            var reacted = _myReactions.Contains(emoji.Native);
            <button class="quick-reaction @(reacted ? "reacted" : "")"
                    title="@emoji.Name"
                    @onclick="@(() => OnQuickReact(emoji))"
                    @onclick:stopPropagation="true">
                <img class="emoji"
                     src="@EmojiSourceProvider.GetSrcUrlFromReaction(emoji.Native, Data.Message.PlanetId)"
                     alt="@emoji.Native"/>
            </button>
        }
        <button class="quick-reaction more"
                title="More reactions"
                @onclick="@OnOpenPicker"
                @onclick:stopPropagation="true">
            <i class="bi bi-emoji-smile"></i>
        </button>
    </div>
}

<ContextMenuItem OnClickAsync="@OnClickReply">
    <Label>Reply</Label>
    <Icon><i class="bi bi-reply-fill"></i></Icon>
</ContextMenuItem>

<ContextMenuItem OnClickAsync="@OnClickMarkUnread">
    <Label>Mark Unread</Label>
    <Icon><i class="bi bi-envelope-fill"></i></Icon>
</ContextMenuItem>

@if (Data.Message.Reactions is not null && Data.Message.Reactions.Count > 0)
{
    <ContextMenuItem OnClickAsync="@OnClickReactions">
        <Label>Reactions</Label>
        <Icon><i class="bi bi-emoji-smile-fill"></i></Icon>
    </ContextMenuItem>
}

@if (Data.Message.AuthorUserId == Client.Me.Id)
{
    <ContextMenuItem OnClickAsync="@OnClickEdit">
        <Label>Edit</Label>
        <Icon><i class="bi bi-pen-fill"></i></Icon>
    </ContextMenuItem>
}

@if (_authorMember is not null)
{
    <ContextSubMenu>
        <Label>Member</Label>
        <Icon><i class="bi bi-caret-right-fill"></i></Icon>
        <Content>
            <MemberContextMenu Data="@_memberContextData" />
        </Content>
    </ContextSubMenu>
}

<ContextSubMenu>
    <Label>Copy</Label>
    <Icon><i class="bi bi-caret-right-fill"></i></Icon>
    <Content>
        <ContextMenuItem OnClickAsync="@OnClickCopyText">Text</ContextMenuItem>
        <ContextMenuItem OnClickAsync="@OnClickCopyLink">Link</ContextMenuItem>
        <ContextMenuItem OnClickAsync="@OnClickCopyId">Message Id</ContextMenuItem>
    </Content>
</ContextSubMenu>

@if (_deletePermission == PermissionState.True)
{
    <ContextMenuItem OnClickAsync="@OnClickDelete" Color="red">
        <Label>Delete</Label>
        <Icon><i class="bi bi-trash-fill"></i></Icon>
    </ContextMenuItem>
}

<ContextMenuItem OnClickAsync="@OnClickReport" Color="red">
    <Label>Report</Label>
    <Icon><i class="bi bi-flag-fill"></i></Icon>
</ContextMenuItem>


@code {
    
    public class MessageContextParams
    {
        public Message Message;
        public ChatWindowComponent WindowComponent;
        public MessageComponent MessageComponent;
    }

    [CascadingParameter]
    public ModalRoot ModalRoot { get; set; }

    private PlanetMember _authorMember;
    private PermissionState _deletePermission = PermissionState.False;
    private MemberContextMenu.MemberContextParams _memberContextData;

    private List<EmojiClickEvent> _quickEmojis;
    private HashSet<string> _myReactions = new();
    private bool _canUseReactions;

    protected override async Task OnInitializedAsync()
    {
        _canUseReactions =
            Data.WindowComponent?.ChannelPermissions is null ||
            Data.WindowComponent.ChannelPermissions.GetPermissionState(ChatChannelPermissions.UseReactions) == PermissionState.True;

        if (_canUseReactions)
        {
            _myReactions = Data.Message.Reactions?
                .Where(x => x.AuthorUserId == Client.Me.Id)
                .Select(x => x.Emoji)
                .ToHashSet() ?? new();

            _quickEmojis = await EmojiMart.GetFrequentlyUsedAsync(JsRuntime);
            StateHasChanged();
        }

        if (Data.Message.PlanetId is not null)
        {
            _authorMember = await Data.Message.FetchAuthorMemberAsync();
            _memberContextData = new()
            {
                Member = _authorMember,
            };
        }
        else
        {
            _authorMember = null;
        }

        if (Data.Message.AuthorUserId == Client.Me.Id)
        {
            _deletePermission = PermissionState.True;
        }
        else if (Data.Message.PlanetId is not null && Data.WindowComponent.ChannelPermissions is not null)
        {
            _deletePermission = Data.WindowComponent.ChannelPermissions.GetPermissionState(ChatChannelPermissions.ManageMessages);
        }
        else
        {
            _deletePermission = PermissionState.False;
        }
    }

    private async Task OnQuickReact(EmojiClickEvent emoji)
    {
        await CloseAsync();

        if (_myReactions.Contains(emoji.Native))
        {
            await Data.Message.RemoveReactionAsync(emoji.Native);
        }
        else
        {
            await Data.Message.AddReactionAsync(emoji.Native);

            // Feed emoji-mart's frequency store so the quick row stays accurate
            await EmojiMart.RecordFrequentAsync(JsRuntime, emoji.Id);
        }
    }

    private async Task OnOpenPicker(MouseEventArgs e)
    {
        await CloseAsync();
        Data.WindowComponent?.OpenReactionPicker(Data.Message, e.ClientX, e.ClientY);
    }

    private async Task OnClickReply()
    {
        // Close the context menu
        await CloseAsync();
        
        var input = Data.MessageComponent.ParamData.ChatComponent.InputComponent;
        await input.SetReplyMessage(Data.Message);
    }

    private async Task OnClickReactions()
    {
        await CloseAsync();

        ModalRoot.OpenModal<ReactionsModalComponent>(new ReactionsModalComponent.ModalParams
        {
            Message = Data.Message
        });
    }

    private async Task OnClickMarkUnread()
    {
        await CloseAsync();
        
        var result = await Data.Message.MarkUnreadAsync();
        if (result.Success)
        {
            ToastContainer.Instance.AddToast(new ToastData("Marked Unread", "Message marked as unread", ToastProgressState.Success));
        }
        else
        {
            ToastContainer.Instance.AddToast(new ToastData("Unable to Mark Unread", result.Message, ToastProgressState.Failure));
        }
    }

    private async Task OnClickDelete()
    {
        await CloseAsync();

        var message = Data.Message;

        var previewParams = new MessageComponent.Params
        {
            ChatComponent = Data.MessageComponent.ParamData.ChatComponent,
            Message = message,
            LastMessage = null,
            IsInnerReply = false,
            Ghost = false
        };

        var data = new ConfirmModalComponent.ModalParams("Delete message?", message.Content, "Delete", "Cancel",
            async () =>
            {
                await message.DeleteAsync();
            },
            () => Task.CompletedTask
        )
        {
            DescriptionFragment = @<div class="message-delete-preview">
                <MessageComponent ParamData="@previewParams" />
            </div>
        };

        ModalRoot.OpenModal<ConfirmModalComponent>(data);
    }

    private async Task OnClickReport()
    {
        await CloseAsync();
        
        var data = new ReportModalComponent.ModalParams()
        {
            Report = new Report()
            {
                ReportingUserId = Client.Me.Id,
                MessageId = Data.MessageComponent.ParamData.Message.Id,
                ChannelId = Data.MessageComponent.ParamData.Message.ChannelId,
                PlanetId = Data.MessageComponent.ParamData.Message.PlanetId,
                ReportedUserId = Data.Message.AuthorUserId
            },
            ReportedMemberId = _authorMember?.Id
        };
        
        ModalRoot.OpenModal<ReportModalComponent>(data);
    }

    private async Task OnClickEdit()
    {
        await CloseAsync();
        await Data.MessageComponent.OpenEditMode();
    }

	    private async Task OnClickCopyText(){
        await JsRuntime.InvokeVoidAsync("clipboardCopy.copyText", Data.Message.Content);
        ToastContainer.Instance.AddToast(new ToastData("Copied!", "Message text copied to clipboard", ToastProgressState.Success));
    }

    private async Task OnClickCopyId(){
        await JsRuntime.InvokeVoidAsync("clipboardCopy.copyText", Data.Message.Id.ToString());
        ToastContainer.Instance.AddToast(new ToastData("Copied!", "Message ID copied to clipboard", ToastProgressState.Success));
    }

    private async Task OnClickCopyLink(){
        var message = Data.Message;
        var baseUri = NavManager.BaseUri.TrimEnd('/');

        // Matches the deep-link routes on Index.razor
        var url = message.PlanetId is not null
            ? $"{baseUri}/planetchannels/{message.PlanetId.Value}/{message.ChannelId}/{message.Id}"
            : $"{baseUri}/directchannels/{message.ChannelId}/{message.Id}";

        await JsRuntime.InvokeVoidAsync("clipboardCopy.copyText", url);
        ToastContainer.Instance.AddToast(new ToastData("Copied!", "Message link copied to clipboard", ToastProgressState.Success));
    }
}
