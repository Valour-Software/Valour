@page "/I/{InviteCode}"

@inject ValourClient Client
@inject PlanetService PlanetService

<PlanetJoinLanding Result="@_inviteDataResult"
                   JoinAsync="@JoinAsync"
                   LoginReturnPath="@($"/I/{InviteCode}")"
                   RegisterUrl="@($"/register/i/{InviteCode}")" />

@code {

    [Parameter]
    public string InviteCode { get; set; }

    private TaskResult<PlanetListInfo>? _inviteDataResult;

    protected override async Task OnInitializedAsync()
    {
        var inviteDataTask = PlanetService.FetchInviteScreenDataAsync(InviteCode);
        var joinedPlanetsTask = Client.IsLoggedIn ? PlanetService.FetchJoinedPlanetsAsync() : Task.CompletedTask;
        await joinedPlanetsTask;
        _inviteDataResult = await inviteDataTask;
    }

    private Task<TaskResult<PlanetMember>> JoinAsync(long planetId) =>
        PlanetService.JoinPlanetAsync(planetId, InviteCode);
}
