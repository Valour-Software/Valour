@page "/D/{PlanetId:long}"

@inject NavigationManager NavManager
@inject ValourClient Client
@inject PlanetService PlanetService

<NebulaBackground ContentClasses="absolute-center">
    <div class="invite-card">
        <div class="col-md-12">
            <section class="text-center">

                @if (_planetInfoResult is null)
                {
                    <h2>Loading...</h2>
                }
                else if (!_planetInfoResult.Value.Success)
                {
                    <p class="invite-prompt text-danger">@(_planetInfoResult.Value.Message ?? "An error occurred.")</p>
                    <button class="v-btn center mt-4" @onclick="OnClose">Back to Home</button>
                }
                else
                {
                    if (!Client.IsLoggedIn)
                    {
                        <div class="invite-planet-preview">
                            <DiscoveryPlanetCard PlanetInfo="@_planetInfoResult.Value.Data" HideActions="true"/>
                        </div>
                        <p class="invite-prompt">Create an account or log in to join this planet</p>
                        <div class="invite-actions">
                            <button class="v-btn mt-2 join-btn" @onclick="OnClickRegister">Join Valour</button>
                            <button class="v-btn mt-2 login-btn" @onclick="OnClickLogin">Log In</button>
                        </div>
                    }
                    else if (_alreadyJoined)
                    {
                        <DiscoveryPlanetCard PlanetInfo="@_planetInfoResult.Value.Data" HideActions="true"/>
                        <p class="already-joined-text">You're already a member of this planet!</p>
                        <button class="v-btn mt-2" @onclick="OnClose">Go to Home</button>
                    }
                    else
                    {
                        <DiscoveryPlanetCard PlanetInfo="@_planetInfoResult.Value.Data" OnJoin="OnJoinPlanet"/>
                        @if (_joining)
                        {
                            <p class="invite-prompt">Joining planet...</p>
                        }
                        else if (_joinError is not null)
                        {
                            <p class="invite-prompt text-danger">@_joinError</p>
                        }
                    }
                }
            </section>
        </div>
    </div>
</NebulaBackground>

@code {

    [Parameter]
    public long PlanetId { get; set; }

    private TaskResult<PlanetListInfo>? _planetInfoResult;
    private bool _alreadyJoined = false;
    private string _joinError;
    private bool _joining;

    protected override async Task OnInitializedAsync()
    {
        var planetInfoTask = PlanetService.FetchPlanetInfoAsync(PlanetId);
        var joinedPlanetsTask = Client.IsLoggedIn ? PlanetService.FetchJoinedPlanetsAsync() : Task.CompletedTask;
        await joinedPlanetsTask;
        _planetInfoResult = await planetInfoTask;

        // This page is only meant to be reachable via a discoverable planet's
        // link. A planet that's public but not discoverable should look like
        // it doesn't exist here, the same as a private or missing planet.
        if (_planetInfoResult.Value.Success &&
            _planetInfoResult.Value.Data is not null &&
            !_planetInfoResult.Value.Data.Discoverable)
        {
            _planetInfoResult = TaskResult<PlanetListInfo>.FromFailure("Planet not found or not public");
        }

        if (_planetInfoResult.HasValue &&
            _planetInfoResult.Value.Data is not null &&
            IsAlreadyJoined(_planetInfoResult.Value.Data.PlanetId))
        {
            _alreadyJoined = true;
        }
    }

    private bool IsAlreadyJoined(long planetId)
    {
        var planets = PlanetService.JoinedPlanets;
        for (var i = 0; i < planets.Count; i++)
        {
            if (planets[i].Id == planetId)
                return true;
        }
        return false;
    }

    public async Task OnClose()
    {
        await PlanetService.FetchJoinedPlanetsAsync();
        NavManager.NavigateTo("/");
    }

    private void OnClickLogin()
    {
        NavManager.NavigateTo($"/?redirect=/d/{PlanetId}", true);
    }

    private void OnClickRegister()
    {
        NavManager.NavigateTo("/register", true);
    }

    private async Task OnJoinPlanet(PlanetListInfo planetInfo)
    {
        if (_joining)
            return;

        _joinError = null;
        _joining = true;
        StateHasChanged();

        TaskResult<PlanetMember> result;
        try
        {
            result = await PlanetService.JoinPlanetAsync(planetInfo.PlanetId);
        }
        finally
        {
            _joining = false;
        }

        if (result.Success)
        {
            _alreadyJoined = true;
            await GoToPlanetAsync(planetInfo.PlanetId);
            return;
        }

        await PlanetService.FetchJoinedPlanetsAsync();
        if (IsAlreadyJoined(planetInfo.PlanetId))
        {
            _alreadyJoined = true;
            await GoToPlanetAsync(planetInfo.PlanetId);
            return;
        }

        _joinError = result.Message ?? "Failed to join planet.";
    }

    private async Task GoToPlanetAsync(long planetId)
    {
        var planet = await PlanetService.FetchPlanetAsync(planetId);
        if (planet is not null)
        {
            await planet.FetchInitialDataAsync();
            var channel = planet.PrimaryChatChannel;
            if (channel is not null)
            {
                NavManager.NavigateTo($"/planetchannels/{planetId}/{channel.Id}/0", true);
                return;
            }
        }

        await PlanetService.FetchJoinedPlanetsAsync();
        NavManager.NavigateTo("/", true);
    }
}
