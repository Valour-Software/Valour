@page "/"
@page "/planetchannels/{StartPlanetId:long}/{StartChannelId:long}/{StartMessageId:long}"
@page "/directchannels/{StartChannelId:long}/{StartMessageId:long}"
@page "/planetthreads/{StartPlanetId:long}/{StartThreadId:long}"
@page "/planetthreads/{StartPlanetId:long}"
@page "/planetwiki/{StartPlanetId:long}/{StartPageId:long}"
@page "/planetwiki/{StartPlanetId:long}"
@using Valour.Sdk.Services

@inject ValourClient Client
@inject AuthService AuthService
@inject IJSRuntime JsRuntime
@inject NavigationManager NavigationManager

<PushSubscriptionsComponent />
<Valour.Client.Components.Demo.DemoDirector />

<!-- Check login status -->
@if (!Client.IsLoggedIn)
{
	<LoginComponent FromVerified="false"></LoginComponent>
	return;
}

<!-- 
<ChangeLogComponent />
-->

<SafetyPopup />
<ProfilePopup />
<CustomDropdownContent />

<div class="mobile-holder @MobileClass @EmbeddedClass">
	<ToastContainer>
		<!-- Modal management -->
		<ModalRoot>
			<ValourErrorBoundary>
				<ContextMenuRoot>

					<ModalInjector/>

					<AppRecedeLayer>
					<body class="mainrow">
					<Sidebar></Sidebar>
					<div class="channel-and-topbar" id="mainwindow">
						<div class="topbar">
							@if (DeviceInfo.IsMobile)
							{
								<i class="bi bi-list sidebar-toggle" @onclick="Sidebar.ToggleMobileSidebar"></i>
							}
							<QuickNotifComponent />
							@if (DeviceInfo.IsMobile)
							{
								<i class="bi bi-house-door-fill home" role="button" aria-label="Go Home" title="Go Home" @onclick="OnClickHome"></i>
							}
						</div>
						<!-- It's so nice when it's hidden away, just like my fears -->
						<WindowDockComponent StartRoute="@_startRoute" />
					</div>
					@* 
				       @if (!DeviceInfo.IsMobile)
					   {
   						<Sidebar Flip="@true"></Sidebar>
					   }
					*@

					</body>
					</AppRecedeLayer>
				</ContextMenuRoot>
			</ValourErrorBoundary>
		</ModalRoot>
	</ToastContainer>
</div>


@code {
	// The relative route the app launched with (e.g. a notification deep link or
	// a shared Valour URL). The dock parses it via ValourRouteParser to open the
	// right channel/thread as the initial window.
	private string _startRoute;

	// These route parameters are required so the @page templates bind, but the
	// dock now resolves the destination straight from the URL.
	[Parameter]
	public long? StartPlanetId { get; set; }
	
	[Parameter]
	public long? StartChannelId { get; set; }
	
	[Parameter]
	public long? StartMessageId { get; set; }

	[Parameter]
	public long? StartThreadId { get; set; }

	[Parameter]
	public long? StartPageId { get; set; }

	private string MobileClass => DeviceInfo.IsMobile ? "mobile" : "desktop";
	
	private string EmbeddedClass => DeviceInfo.IsEmbedded ? "embedded" : "";

	protected override async Task OnInitializedAsync()
	{
		_startRoute = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);

		await base.OnInitializedAsync();

		WindowService.FocusedPlanetChanged += OnPlanetChange;
		AuthService.LoggedIn += OnLoginAsync;
	}

	private async Task OnLoginAsync(User user)
	{
		await InvokeAsync(StateHasChanged);
	}

	public void Dispose()
	{
		WindowService.FocusedPlanetChanged -= OnPlanetChange;
	}

	private Task OnPlanetChange(Planet planet)
	{
		if (planet != null)
		{
			Console.WriteLine("Index planet change: " + planet.Name);
		}
		else
		{
			Console.WriteLine("Index planet change: null");
		}

		return Task.CompletedTask;
	}

	private async Task OnClickHome()
	{
		await WindowService.OpenWindowAtFocused(ThreadsWindowComponent.DefaultContent);
	}

	public void ForceRefresh()
	{
		StateHasChanged();
	}
}
