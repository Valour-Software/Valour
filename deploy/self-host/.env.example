# Copy this file to ".env" before starting the stack.
#
# This file is the main operator config surface for self-hosting.
# Most people should only need to edit this file.

# ------------------------------------------------------------
# Docker images
# ------------------------------------------------------------

# Valour backend image to run.
# Prefer a fixed tag for production rather than following "main" forever.
VALOUR_IMAGE=ghcr.io/valour-software/valour:main

# Supporting service images.
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
NGINX_IMAGE=nginx:1.27-alpine

# ------------------------------------------------------------
# Basic app settings
# ------------------------------------------------------------

ASPNETCORE_ENVIRONMENT=Production

# Public ports on your server.
# In most setups you should keep these as 80 and 443.
HTTP_PORT=80
HTTPS_PORT=443

# Hostnames that Nginx should answer for.
# For the simplest supported setup, use a single hostname for the
# web app, API, and SignalR endpoint together.
# You can add more than one hostname by separating them with spaces.
SERVER_NAMES=chat.example.com

# Public HTTPS base URL used by the node and client.
# In the recommended deployment, this matches the same hostname
# that serves the frontend.
PUBLIC_API_BASE_URL=https://chat.example.com

# Internal app container address. Do not change unless you know why.
UPSTREAM_HOST=dotnetapp
UPSTREAM_PORT=5000

# Upload and websocket proxy limits.
CLIENT_MAX_BODY_SIZE=250M
PROXY_READ_TIMEOUT=100s

# ------------------------------------------------------------
# TLS certificate files
# ------------------------------------------------------------

# Paths are relative to deploy/self-host/ unless you use absolute paths.
# These can point to either:
# - a normal public certificate and key
# - a Cloudflare Origin CA certificate and key when using Cloudflare proxying
TLS_CERT_PATH=./nginx/ssl/server.crt
TLS_KEY_PATH=./nginx/ssl/server.key

# ------------------------------------------------------------
# PostgreSQL settings
# ------------------------------------------------------------

POSTGRES_DB=valour
POSTGRES_USER=valour

# Change this to a strong password before starting the stack.
POSTGRES_PASSWORD=change-me

# ------------------------------------------------------------
# Valour node identity
# ------------------------------------------------------------

# Friendly name for this backend node.
NODE_NAME=community-node

# Shared node key for this installation.
# Generate a long random value before going live.
NODE_KEY=change-me

# ------------------------------------------------------------
# Optional ASP.NET / Valour settings
# ------------------------------------------------------------

# Add additional configuration here only if you need the related feature.
# Examples:
#
# Uploads / media storage (S3-compatible)
# CDN__S3Access=
# CDN__S3Secret=
# CDN__S3Endpoint=
# CDN__PublicS3Access=
# CDN__PublicS3Secret=
# CDN__PublicS3Endpoint=
#
# Email
# Email__ApiKey=
#
# Cloudflare cache purge / voice
# Cloudflare__ApiKey=
# Cloudflare__ZoneId=
# Cloudflare__RealtimeAccountId=
# Cloudflare__RealtimeAppId=
# Cloudflare__RealtimeApiToken=
#
# Push notifications with a mounted Firebase credentials file
# Notifications__FirebaseCredentialPath=/app/firebase-credentials.json
