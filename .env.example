# Copy to .env and edit before running docker compose up -d
# (.env is gitignored — never commit real values)

# The domain this instance is served from. DNS must point at this machine;
# Caddy obtains TLS certificates automatically.
VALOUR_DOMAIN=valour.example.com

# Display name shown to clients
VALOUR_INSTANCE_NAME=My Valour

# Database password (also the default MinIO password if the minio profile is used)
POSTGRES_PASSWORD=change-me

# First-run staff account. Created once, only if no staff account exists.
# Remove or leave empty to skip.
VALOUR_ADMIN_EMAIL=admin@example.com
VALOUR_ADMIN_PASSWORD=change-me-too
