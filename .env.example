# Copy to .env and edit before running docker compose up -d
# (.env is gitignored — never commit real values)

# The domain this instance is served from. DNS must point at this machine;
# Caddy obtains TLS certificates automatically.
VALOUR_DOMAIN=valour.example.com

# Display name shown to clients
VALOUR_INSTANCE_NAME=My Valour

# Database password (also the default MinIO password if the minio profile is used)
POSTGRES_PASSWORD=change-me

# First-run staff account. Created once, only if no staff account exists.
# Remove or leave empty to skip.
VALOUR_ADMIN_EMAIL=admin@example.com
VALOUR_ADMIN_PASSWORD=change-me-too

# --- Federation community node (optional) ---
# This self-hosted Compose bundle configures a community node only. Official
# Valour hub replicas set Federation:HubEnabled=true in their private cluster
# configuration and share one database plus one Data Protection KEK.
# Run ./scripts/valour-node-setup after the basic settings above are complete.
# It configures the following values, generates a stable 32-byte KEK, and
# explains the hub registration / verification ceremony. Keep the real .env
# private: the KEK must never be committed or shared.
# FEDERATION__HUBURL=https://valour.gg
# FEDERATION__NODEDOMAIN=community.example.com
# FEDERATION__NODECHALLENGE=
# FEDERATION__ALLOWPUBLICMIGRATIONS=false
# DATAPROTECTION__KEK=

# --- Self-hosted voice/video (optional) ---
# Leave blank to keep voice disabled. To enable, run the voice Compose overlay
#   docker compose -f docker-compose.yml -f docker-compose.voice.yml up -d
# and see Docs/Deployment/SelfHostVoice.md for DNS, Caddy, and firewall setup.
# VOICE_PROVIDER=livekit
# Public websocket URL clients connect to (needs DNS + the Caddy voice block):
# VOICE_LIVEKIT_URL=wss://voice.valour.example.com
# API key/secret the server signs LiveKit tokens with. Generate a long random
# secret (>= 32 chars), e.g.:  openssl rand -hex 32
# VOICE_LIVEKIT_API_KEY=valour
# VOICE_LIVEKIT_API_SECRET=change-me-to-a-long-random-secret
